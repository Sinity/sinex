export NIXPKGS_ALLOW_UNFREE=1
if [ -z "${DEVENV_ROOT:-}" ]; then
  export DEVENV_ROOT="$PWD"
fi
if [ -z "${DEVENV_DOTFILE:-}" ]; then
  export DEVENV_DOTFILE="$DEVENV_ROOT/.devenv"
fi
# Suppress verbose task output from devenv.
export DEVENV_TASKS_QUIET=1
export DEVENV_TUI=false

# Load devenv environment (fails fast if missing).
if command -v devenv >/dev/null 2>&1; then
  # Use devenv's direnv integration so evaluations are cached and watched.
  eval "$(devenv direnvrc)"

  # Serialize devenv evaluations to prevent RAM exhaustion from concurrent reloads.
  # This is especially important for IDEs that may trigger multiple reloads in parallel.
  mkdir -p "$DEVENV_DOTFILE"
  exec 200>"$DEVENV_DOTFILE/direnv-eval.lock"
  if ! flock -n 200; then
    echo "devenv: waiting for other evaluations to finish..." >&2
    flock -x 200
  fi

  # Force devenv to use cached evaluation if available (reduces concurrent evals)
  use devenv --impure --quiet

  exec 200>&-
else
  # Fallback: run devenv ad-hoc via nix without installing into a profile.
  eval "$(nix run --quiet --accept-flake-config github:cachix/devenv/latest -- print-dev-env --impure)"
fi

# Note: devenv's direnvrc already sets up intelligent file watching.
# The default watches include devenv.nix, devenv.lock, flake.nix, and flake.lock.
# Additional watch_file directives are usually unnecessary and may interfere.
