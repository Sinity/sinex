if [ -f scripts/dev-env-banner.sh ]; then
  watch_file scripts/dev-env-banner.sh
fi

# Ensure devenv state lives inside the real checkout rather than a
# read-only /nix/store copy when direnv evaluates the flake.
if [ -z "${DEVENV_ROOT:-}" ]; then
  export DEVENV_ROOT="$PWD"
fi
if [ -z "${DEVENV_DOTFILE:-}" ]; then
  export DEVENV_DOTFILE="$DEVENV_ROOT/.devenv"
fi

use flake . --no-pure-eval

if [ -x ./scripts/dev-env-banner.sh ] && [ -z "${SINEX_DEVENV_MOTD_ONCE:-}" ]; then
  ./scripts/dev-env-banner.sh || true
  export SINEX_DEVENV_MOTD_ONCE=1
fi

# Ensure Postgres tooling always has the correct credentials even if the host
# environment overrides them (we've seen PGUSER default to literal "$USER").
export PGHOST="/run/postgresql"
export PGUSER="sinity"
export PGDATABASE="sinex_dev"
export DATABASE_URL="postgresql:///sinex_dev?host=/run/postgresql"
