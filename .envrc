if [ -z "${DEVENV_ROOT:-}" ]; then
  export DEVENV_ROOT="$PWD"
fi
if [ -z "${DEVENV_DOTFILE:-}" ]; then
  export DEVENV_DOTFILE="$DEVENV_ROOT/.devenv"
fi
# Suppress verbose task output from devenv.
export DEVENV_TASKS_QUIET=1

# Load devenv environment (fails fast if missing).
if command -v devenv >/dev/null 2>&1; then
  eval "$(devenv shell --print-env)"
else
  echo "devenv not found; please install devenv." >&2
  exit 1
fi
