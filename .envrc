if [ -z "${DEVENV_ROOT:-}" ]; then
  export DEVENV_ROOT="$PWD"
fi
if [ -z "${DEVENV_DOTFILE:-}" ]; then
  export DEVENV_DOTFILE="$DEVENV_ROOT/.devenv"
fi
# Suppress verbose task output from devenv.
export DEVENV_TASKS_QUIET=1

# Load devenv environment (fails fast if missing).
if command -v devenv >/dev/null 2>&1; then
  # --impure is required so the flake inputs (e.g., fenix) can resolve without
  # pure-mode lockfile updates erroring out.
  eval "$(devenv print-dev-env --impure)"
else
  # Fallback: run devenv ad-hoc via nix without installing into a profile.
  eval "$(nix run --quiet --accept-flake-config github:cachix/devenv/latest -- print-dev-env --impure)"
fi
