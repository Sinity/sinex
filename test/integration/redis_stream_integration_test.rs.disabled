        // Verify exactly 3 messages
        assert_eq!(message_ids.len(), 3);
        
        // Check stream length matches
        let stream_len: usize = redis_conn.xlen(stream_key).await?;
        assert_eq!(stream_len, 3);
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === CORE FUNCTIONALITY TESTS ===

// Test basic stream lifecycle
test_redis_stream_operations!(
    test_stream_lifecycle,
    "sinex:test:lifecycle",
    "lifecycle-group",
    5,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Verify all messages were processed
        assert_eq!(message_ids.len(), 5);
        assert_eq!(result.keys.len(), 1);
        
        // Verify stream exists and has correct length
        let stream_len: usize = redis_conn.xlen(stream_key).await?;
        assert_eq!(stream_len, 5);
        
        // Verify consumer group info
        let groups: Vec<HashMap<String, String>> = redis_conn.xinfo_groups(stream_key).await?;
        assert_eq!(groups.len(), 1);
        assert_eq!(groups[0].get("name"), Some(&"lifecycle-group".to_string()));
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// Test message ordering preservation
test_redis_stream_operations!(
    test_message_ordering,
    "sinex:test:ordering",
    "ordering-group",
    10,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        let stream = &result.keys[0];
        
        // Extract and verify message ordering
        let mut indices = Vec::new();
        for message in &stream.ids {
            if let Some(index_val) = message.map.get("index") {
                if let redis::Value::Data(bytes) = index_val {
                    let index_str = String::from_utf8_lossy(bytes);
                    indices.push(index_str.parse::<usize>()?);
                }
            }
        }
        
        // Messages should be in sequential order
        for i in 1..indices.len() {
            assert!(indices[i] > indices[i-1], "Messages not in order: {:?}", indices);
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// Test consumer group state management
test_redis_stream_operations!(
    test_consumer_group_state,
    "sinex:test:consumer-state",
    "state-group",
    3,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Verify consumer group was created and has pending messages initially
        let groups: Vec<HashMap<String, String>> = redis_conn.xinfo_groups(stream_key).await?;
        let group = &groups[0];
        
        // After acknowledgment, pending should be 0
        let pending: i64 = group.get("pending").unwrap_or(&"0".to_string()).parse()?;
        assert_eq!(pending, 0, "Should have no pending messages after ACK");
        
        // Verify consumers exist
        let consumers: Vec<HashMap<String, String>> = redis_conn
            .xinfo_consumers(stream_key, "state-group").await?;
        assert!(!consumers.is_empty(), "Should have at least one consumer");
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === ERROR HANDLING TESTS ===

// Test handling of duplicate consumer group creation
test_redis_stream_operations!(
    test_duplicate_consumer_group,
    "sinex:test:duplicate-group",
    "duplicate-group",
    2,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Try to create the same consumer group again - should not fail
        let group_result = redis_conn.xgroup_create::<_, _, _, String>(
            stream_key, "duplicate-group", "0"
        ).await;
        
        // Should either succeed or give BUSYGROUP error (both acceptable)
        match group_result {
            Ok(_) => {}, // Group created successfully
            Err(e) if e.to_string().contains("BUSYGROUP") => {}, // Group already exists
            Err(e) => panic!("Unexpected error: {}", e),
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// Test recovery from consumer failure simulation
test_redis_stream_operations!(
    test_consumer_failure_recovery,
    "sinex:test:failure-recovery",
    "recovery-group",
    5,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Simulate reading without acknowledgment (consumer failure)
        use redis::cmd;
        let unacked_result = cmd("XREADGROUP")
            .arg("GROUP")
            .arg("recovery-group")
            .arg("failed-consumer")
            .arg("COUNT")
            .arg(2)
            .arg("STREAMS")
            .arg(stream_key)
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(redis_conn)
            .await?;
        
        // Verify pending messages exist
        let groups: Vec<HashMap<String, String>> = redis_conn.xinfo_groups(stream_key).await?;
        let pending: i64 = groups[0].get("pending").unwrap_or(&"0".to_string()).parse()?;
        assert!(pending > 0, "Should have pending messages from failed consumer");
        
        // Claim and acknowledge the pending messages (recovery)
        if let Some(stream) = unacked_result.keys.first() {
            for message in &stream.ids {
                let _: i64 = redis_conn.xack(stream_key, "recovery-group", &[&message.id]).await?;
            }
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === CONCURRENCY TESTS ===

// Test multiple consumer coordination
test_redis_stream_operations!(
    test_multiple_consumers,
    "sinex:test:multi-consumer",
    "multi-group",
    20,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Create additional consumers
        use redis::cmd;
        
        // Consumer 2
        let consumer2_result = cmd("XREADGROUP")
            .arg("GROUP")
            .arg("multi-group")
            .arg("consumer-2")
            .arg("COUNT")
            .arg(5)
            .arg("STREAMS")
            .arg(stream_key)
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(redis_conn)
            .await?;
        
        // Consumer 3
        let consumer3_result = cmd("XREADGROUP")
            .arg("GROUP")
            .arg("multi-group")
            .arg("consumer-3")
            .arg("COUNT")
            .arg(5)
            .arg("STREAMS")
            .arg(stream_key)
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(redis_conn)
            .await?;
        
        // Acknowledge messages from additional consumers
        for result in &[consumer2_result, consumer3_result] {
            for stream in &result.keys {
                for message in &stream.ids {
                    let _: i64 = redis_conn.xack(stream_key, "multi-group", &[&message.id]).await?;
                }
            }
        }
        
        // Verify all consumers are registered
        let consumers: Vec<HashMap<String, String>> = redis_conn
            .xinfo_consumers(stream_key, "multi-group").await?;
        assert!(consumers.len() >= 3, "Should have at least 3 consumers");
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === INTEGRATION TESTS ===

// Test Redis stream integration with event processing patterns
test_redis_stream_operations!(
    test_event_processing_pattern,
    "sinex:test:event-processing",
    "processing-group",
    8,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Simulate typical Sinex event processing pattern
        let stream = &result.keys[0];
        
        let mut processed_events = Vec::new();
        for message in &stream.ids {
            // Extract event data (simulating automaton processing)
            let event_data = json!({
                "stream_id": message.id,
                "index": message.map.get("index").and_then(|v| match v {
                    redis::Value::Data(bytes) => String::from_utf8(bytes.clone()).ok(),
                    _ => None
                }).unwrap_or_else(|| "0".to_string()),
                "processed_at": chrono::Utc::now().to_rfc3339(),
                "processing_result": "success"
            });
            processed_events.push(event_data);
        }
        
        // Verify processing results
        assert_eq!(processed_events.len(), stream.ids.len());
        assert!(processed_events.len() <= 8); // Should process up to 8 messages
        
        // All events should have required fields
        for event in &processed_events {
            assert!(event.get("stream_id").is_some());
            assert!(event.get("processed_at").is_some());
            assert_eq!(event.get("processing_result").unwrap(), "success");
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === BOUNDARY CONDITION TESTS ===

// Test large message handling
test_redis_stream_operations!(
    test_large_messages,
    "sinex:test:large-messages",
    "large-group",
    3,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Add a large message to test size limits
        let large_payload = "x".repeat(1024 * 10); // 10KB message
        let large_message_data = &[
            ("type", "large_payload"),
            ("data", large_payload.as_str()),
            ("size", "10240"),
        ];
        
        let large_id: String = redis_conn.xadd(stream_key, "*", large_message_data).await?;
        
        // Read the large message
        use redis::cmd;
        let large_result = cmd("XREADGROUP")
            .arg("GROUP")
            .arg("large-group")
            .arg("large-consumer")
            .arg("COUNT")
            .arg(1)
            .arg("STREAMS")
            .arg(stream_key)
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(redis_conn)
            .await?;
        
        // Verify large message was handled correctly
        if let Some(stream) = large_result.keys.first() {
            if let Some(message) = stream.ids.first() {
                assert!(message.map.contains_key("data"));
                let _: i64 = redis_conn.xack(stream_key, "large-group", &[&message.id]).await?;
            }
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// Test stream memory management
test_redis_stream_operations!(
    test_stream_memory_management,
    "sinex:test:memory",
    "memory-group",
    50,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Verify stream length before trimming
        let initial_len: usize = redis_conn.xlen(stream_key).await?;
        assert!(initial_len >= 50);
        
        // Trim stream to test memory management
        use redis::streams::StreamMaxlen;
        let trimmed: i64 = redis_conn.xtrim(stream_key, StreamMaxlen::Equals(25)).await?;
        assert!(trimmed >= 25, "Should have trimmed at least 25 messages");
        
        // Verify stream length after trimming
        let final_len: usize = redis_conn.xlen(stream_key).await?;
        assert!(final_len <= 25, "Stream should be trimmed to 25 messages or fewer");
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === RELIABILITY TESTS ===

// Test idempotent operations
test_redis_stream_operations!(
    test_idempotent_operations,
    "sinex:test:idempotent",
    "idempotent-group",
    5,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Try to acknowledge the same messages multiple times
        let stream = &result.keys[0];
        
        for message in &stream.ids {
            // First ACK should succeed (already done by macro)
            // Second ACK should be harmless
            let ack_result: i64 = redis_conn
                .xack(stream_key, "idempotent-group", &[&message.id]).await?;
            // ack_result will be 0 for already-acknowledged messages
        }
        
        // Verify no errors occurred and stream state is consistent
        let groups: Vec<HashMap<String, String>> = redis_conn.xinfo_groups(stream_key).await?;
        assert_eq!(groups.len(), 1);
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// Test stream persistence across reconnections (simulated)
test_redis_stream_operations!(
    test_stream_persistence,
    "sinex:test:persistence",
    "persistence-group",
    10,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Verify stream and consumer group persist
        let stream_len: usize = redis_conn.xlen(stream_key).await?;
        let groups: Vec<HashMap<String, String>> = redis_conn.xinfo_groups(stream_key).await?;
        
        assert!(stream_len >= 10, "Stream should persist with all messages");
        assert_eq!(groups.len(), 1, "Consumer group should persist");
        assert_eq!(groups[0].get("name"), Some(&"persistence-group".to_string()));
        
        // Verify message data integrity
        let all_messages = cmd("XRANGE")
            .arg(stream_key)
            .arg("-")
            .arg("+")
            .query_async::<_, Vec<(String, Vec<(String, String)>)>>(redis_conn)
            .await?;
        
        assert!(!all_messages.is_empty(), "Should have persisted messages");
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// === ENHANCED ERROR TESTING USING ERROR MACROS ===

// Test Redis connection failure using test_error_case! macro
test_error_case!(
    test_redis_connection_failure,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Try to connect to invalid Redis instance
        let invalid_client = redis::Client::open("redis://invalid.host:6379/")
            .map_err(|e| CoreError::Service(e.to_string()))?;
        
        invalid_client.get_multiplexed_async_connection().await
            .map_err(|e| CoreError::Service(e.to_string()))
    },
    CoreErrorVariant::Service
);

// Test Redis stream recovery using test_recovery! macro
test_recovery!(
    test_redis_stream_recovery,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Failing operation: Try to read from non-existent stream
        let client = redis::Client::open("redis://127.0.0.1:6379/")
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let mut conn = client.get_multiplexed_async_connection().await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // This will fail because stream doesn't exist
        use redis::cmd;
        cmd("XREADGROUP")
            .arg("GROUP")
            .arg("non-existent-group")
            .arg("consumer")
            .arg("STREAMS")
            .arg("non-existent-stream")
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(&mut conn)
            .await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)
    },
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Recovery operation: Create stream and consumer group
        let client = redis::Client::open("redis://127.0.0.1:6379/")
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let mut conn = client.get_multiplexed_async_connection().await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // Create stream with initial message
        let _: String = conn.xadd("recovery-stream", "*", &[("recovery", "success")]).await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // Create consumer group
        let _: String = conn.xgroup_create("recovery-stream", "recovery-group", "0").await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // Cleanup
        let _: i64 = conn.del("recovery-stream").await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        Ok::<_, Box<dyn std::error::Error + Send + Sync>>("recovered".to_string())
    }
);

// Test concurrent Redis operations with error handling using test_concurrent_errors! macro
test_concurrent_errors!(
    test_redis_concurrent_consumer_errors,
    10, // 10 concurrent consumers
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        let client = redis::Client::open("redis://127.0.0.1:6379/")
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let mut conn = client.get_multiplexed_async_connection().await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        let stream_key = "concurrent-error-test";
        let group_name = "concurrent-group";
        let consumer_name = format!("consumer-{}", task_id);
        
        // Try to create consumer group (most will fail with BUSYGROUP error)
        match conn.xgroup_create::<_, _, _, String>(stream_key, group_name, "0").await {
            Ok(_) => {},
            Err(e) => {
                // BUSYGROUP errors are expected - the group was already created
                if !e.to_string().contains("BUSYGROUP") {
                    return Err(Box::new(e) as Box<dyn std::error::Error + Send + Sync>);
                }
            }
        }
        
        // All should be able to read (even though group creation failed for most)
        use redis::cmd;
        cmd("XREADGROUP")
            .arg("GROUP")
            .arg(group_name)
            .arg(&consumer_name)
            .arg("COUNT")
            .arg(1)
            .arg("BLOCK")
            .arg(100) // Short timeout
            .arg("STREAMS")
            .arg(stream_key)
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(&mut conn)
            .await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)
    },
    2 // Expect only a couple to actually fail (most BUSYGROUP errors are handled)
);

// Test Redis operation timeout using test_timeout_error! macro
test_timeout_error!(
    test_redis_operation_timeout,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        let client = redis::Client::open("redis://127.0.0.1:6379/")
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let mut conn = client.get_multiplexed_async_connection().await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // This operation will timeout because we're blocking indefinitely on an empty stream
        use redis::cmd;
        cmd("XREADGROUP")
            .arg("GROUP")
            .arg("timeout-group")
            .arg("timeout-consumer")
            .arg("BLOCK")
            .arg(5000) // 5 second block (longer than our timeout)
            .arg("STREAMS")
            .arg("timeout-stream")
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(&mut conn)
            .await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)
    },
    1000 // 1 second timeout (shorter than the Redis block time)
);

// Test Redis batch operations with partial failures using test_partial_failure! macro
test_partial_failure!(
    test_redis_batch_operations_partial_failure,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        let client = redis::Client::open("redis://127.0.0.1:6379/")
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let mut conn = client.get_multiplexed_async_connection().await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        let stream_key = "batch-partial-failure";
        
        // Create stream and consumer group first
        let _: String = conn.xadd(stream_key, "*", &[("init", "stream")]).await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let _: String = conn.xgroup_create(stream_key, "batch-group", "0").await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // Batch operations: Mix of valid and invalid
        let mut results = Vec::new();
        
        // Valid operations
        for i in 0..5 {
            let result: Result<String, redis::RedisError> = conn.xadd(stream_key, "*", &[("valid", format!("message_{}", i))]).await;
            results.push(result.map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>));
        }
        
        // Invalid operations - try to use invalid stream operations
        for _i in 0..3 {
            // Try to create consumer group that already exists (should fail)
            let result = conn.xgroup_create(stream_key, "batch-group", "0").await;
            results.push(result.map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>));
        }
        
        // Cleanup
        let _: Result<i64, _> = conn.del(stream_key).await;
        
        Ok::<_, Box<dyn std::error::Error + Send + Sync>>(results)
    },
    5, // Expected successes (the XADD operations)
    3  // Expected failures (the duplicate group creation attempts)
);

// Test Redis error context preservation using test_error_context! macro
test_error_context!(
    test_redis_error_context_preservation,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        let client = redis::Client::open("redis://127.0.0.1:6379/")
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        let mut conn = client.get_multiplexed_async_connection().await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)?;
        
        // Operation that should fail with context-rich error
        use redis::cmd;
        cmd("XREADGROUP")
            .arg("GROUP")
            .arg("context-group")  // Non-existent group
            .arg("context-consumer")
            .arg("STREAMS")
            .arg("context-stream")  // Non-existent stream
            .arg(">")
            .query_async::<_, redis::streams::StreamReadReply>(&mut conn)
            .await
            .map_err(|e| Box::new(e) as Box<dyn std::error::Error + Send + Sync>)
    },
    vec!["NOGROUP", "stream", "group", "consumer"] // Expected context elements
);