//! Comprehensive Redis Stream Integration Testing Suite
//!
//! This file consolidates all Redis stream testing functionality including:
//! - Functional testing of Redis stream operations
//! - Macro demonstration for test patterns
//! - Enhanced error testing with sophisticated error macros
//!
//! Replaces: redis_stream_comprehensive_test.rs, redis_stream_macro_demo.rs, 
//! and redis_enhanced_error_tests.rs for better maintainability.

use crate::common::prelude::*;
use crate::common::error_helpers::*;
use crate::test_redis_stream_operations;
use redis::AsyncCommands;
use std::collections::HashMap;

// === BASIC REDIS STREAM FUNCTIONALITY TESTS ===

// Basic Redis stream operations test using the macro
test_redis_stream_operations!(
    test_basic_stream_workflow,
    "sinex:test:basic-workflow",
    "test-basic-group",
    10,
    |redis_conn, stream_key, result, message_ids| -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<(), Box<dyn std::error::Error + Send + Sync>>> + Send>> { Box::pin(async move { let redis_conn = redis_conn; let stream_key = stream_key; let result = result; let message_ids = message_ids;
        // Verify the correct number of messages were processed
        assert_eq!(message_ids.len(), 10);
        assert_eq!(result.keys.len(), 1);
        
        // Verify message structure
        let stream = &result.keys[0];
        assert!(stream.ids.len() <= 10); // Should read up to 10 messages
        
        // Verify each message has expected fields
        for message in &stream.ids {
            assert!(message.map.contains_key("index"));
            assert!(message.map.contains_key("test_data"));
            assert!(message.map.contains_key("timestamp"));
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }) }
);

// Test with smaller message count
test_redis_stream_operations!(
