use crate::common::prelude::*;
use serde_json::json;

// Test the new Redis stream operations macro
test_redis_stream_operations!(
    test_basic_redis_stream_flow,
    "sinex:test:macro-validation",
    "test-group",
    5,
    |_redis_conn: &mut redis::aio::Connection<_>, _stream_key: &str, result: &redis::streams::StreamReadReply, message_ids: &Vec<String>| async move {
        // Verify messages were read
        assert_eq!(result.keys.len(), 1);
        assert_eq!(result.keys[0].ids.len(), 5);
        assert_eq!(message_ids.len(), 5);
        
        // Verify message content structure
        for message in &result.keys[0].ids {
            assert!(message.map.contains_key("index"));
            assert!(message.map.contains_key("test_data"));
            assert!(message.map.contains_key("timestamp"));
        }
        
        Ok::<(), Box<dyn std::error::Error + Send + Sync>>(())
    }
);

// Test the schema validation macro - simple version
test_schema_validation!(
    test_valid_schema_simple,
    json!({"name": "test", "value": 42}),
    json!({
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name", "value"],
        "properties": {
            "name": {"type": "string"},
            "value": {"type": "number"}
        }
    }),
    true
);

// Test the schema validation macro - invalid case
test_schema_validation!(
    test_invalid_schema_simple,
    json!({"name": "test", "value": "not_a_number"}),
    json!({
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["name", "value"],
        "properties": {
            "name": {"type": "string"},
            "value": {"type": "number"}
        }
    }),
    false
);

// Test the schema validation macro - complex version
test_schema_validation!(
    test_comprehensive_schema_validation,
    json!({"required_field": "valid"}),
    json!({"missing_field": "invalid"}),
    json!({
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["required_field"],
        "properties": {
            "required_field": {"type": "string"}
        }
    }),
    "required"
);

// Helper function to validate against schema (needed by macro)
fn validate_against_schema(value: &serde_json::Value, schema: &serde_json::Value) -> Result<(), String> {
    // Simple validation for testing - real implementation would use jsonschema crate
    if let (Some(required), Some(value_obj)) = (schema.get("required"), value.as_object()) {
        if let Some(required_array) = required.as_array() {
            for req_field in required_array {
                if let Some(field_name) = req_field.as_str() {
                    if !value_obj.contains_key(field_name) {
                        return Err(format!("Missing required field: {}", field_name));
                    }
                }
            }
        }
    }
    
    if let (Some(props), Some(value_obj)) = (schema.get("properties"), value.as_object()) {
        if let Some(props_obj) = props.as_object() {
            for (field_name, field_value) in value_obj {
                if let Some(field_schema) = props_obj.get(field_name) {
                    if let Some(expected_type) = field_schema.get("type").and_then(|t| t.as_str()) {
                        let actual_type = match field_value {
                            serde_json::Value::String(_) => "string",
                            serde_json::Value::Number(_) => "number",
                            serde_json::Value::Bool(_) => "boolean",
                            serde_json::Value::Array(_) => "array",
                            serde_json::Value::Object(_) => "object",
                            serde_json::Value::Null => "null",
                        };
                        
                        if actual_type != expected_type {
                            return Err(format!("Type mismatch for field {}: expected {}, got {}", 
                                             field_name, expected_type, actual_type));
                        }
                    }
                }
            }
        }
    }
    
    Ok(())
}