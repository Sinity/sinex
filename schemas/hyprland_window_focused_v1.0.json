{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sinex.local/schemas/hyprland/window_focused_v1.0.json",
  "title": "Hyprland Window Focus Event",
  "description": "Schema for Hyprland window focus change events",
  "type": "object",
  "properties": {
    "window_id": {
      "type": "string",
      "pattern": "^0x[0-9a-f]+$",
      "description": "Hexadecimal window identifier"
    },
    "window_title": {
      "type": "string",
      "description": "Current window title"
    },
    "window_class": {
      "type": "string",
      "description": "Window class name"
    },
    "workspace": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1,
          "description": "Workspace ID"
        },
        "name": {
          "type": "string",
          "description": "Workspace name"
        }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    "monitor": {
      "type": "string",
      "description": "Monitor name where window is displayed"
    },
    "geometry": {
      "type": "object",
      "properties": {
        "x": {
          "type": "integer",
          "description": "Window X position"
        },
        "y": {
          "type": "integer",
          "description": "Window Y position"
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "Window width"
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "description": "Window height"
        }
      },
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false
    },
    "focused_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when window gained focus"
    }
  },
  "required": ["window_id", "workspace", "focused_at"],
  "additionalProperties": false
}