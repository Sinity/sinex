{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "blob_id": {
      "type": "string"
    },
    "content_type": {
      "type": "string"
    },
    "hash_sha256": {
      "type": "string"
    },
    "size_bytes": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "stored_at": {
      "$ref": "#/$defs/DateTime"
    }
  },
  "required": [
    "blob_id",
    "content_type",
    "size_bytes",
    "hash_sha256",
    "stored_at"
  ],
  "title": "BlobStoredPayload",
  "type": "object",
  "x-sinex-event-type": "blob.stored",
  "x-sinex-source": "blob_storage",
  "x-sinex-version": "1.0.0"
}
