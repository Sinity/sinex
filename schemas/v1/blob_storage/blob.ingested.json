{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "blob_id": {
      "type": "string"
    },
    "checksum_blake3": {
      "type": "string"
    },
    "deduplicated": {
      "type": "boolean"
    },
    "mime_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "original_filename": {
      "type": "string"
    },
    "size_bytes": {
      "format": "int64",
      "type": "integer"
    }
  },
  "required": [
    "blob_id",
    "size_bytes",
    "checksum_blake3",
    "deduplicated",
    "original_filename"
  ],
  "title": "BlobIngestedPayload",
  "type": "object",
  "x-sinex-event-type": "blob.ingested",
  "x-sinex-source": "blob_storage",
  "x-sinex-version": "1.0.0"
}
