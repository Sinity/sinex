{
  "$defs": {
    "ComponentHealthStatus": {
      "description": "Health status for a system component (health automaton)",
      "enum": [
        "Healthy",
        "Warning",
        "Critical",
        "Unknown"
      ],
      "type": "string"
    },
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "System-wide health status summary",
  "properties": {
    "component_summary": {
      "additionalProperties": {
        "$ref": "#/$defs/ComponentHealthStatus"
      },
      "type": "object"
    },
    "critical_components": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "health_score": {
      "format": "double",
      "type": "number"
    },
    "healthy_components": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "overall_status": {
      "$ref": "#/$defs/ComponentHealthStatus"
    },
    "report_type": {
      "type": "string"
    },
    "total_components": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "warning_components": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "report_type",
    "overall_status",
    "total_components",
    "healthy_components",
    "warning_components",
    "critical_components",
    "health_score",
    "component_summary",
    "generated_at"
  ],
  "title": "HealthSystemStatusPayload",
  "type": "object",
  "x-sinex-event-type": "health.system_status",
  "x-sinex-source": "health-automaton",
  "x-sinex-version": "1.0.0"
}
