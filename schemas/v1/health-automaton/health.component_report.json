{
  "$defs": {
    "ComponentHealthStatus": {
      "description": "Health status for a system component (health automaton)",
      "enum": [
        "Healthy",
        "Warning",
        "Critical",
        "Unknown"
      ],
      "type": "string"
    },
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Component health report from health automaton",
  "properties": {
    "component_name": {
      "type": "string"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "last_seen": {
      "$ref": "#/$defs/DateTime"
    },
    "metrics": {
      "additionalProperties": {
        "format": "double",
        "type": "number"
      },
      "type": "object"
    },
    "minutes_since_last_update": {
      "format": "int64",
      "type": "integer"
    },
    "recent_event_count": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "report_type": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ComponentHealthStatus"
    }
  },
  "required": [
    "report_type",
    "component_name",
    "status",
    "last_seen",
    "metrics",
    "recent_event_count",
    "minutes_since_last_update",
    "generated_at"
  ],
  "title": "HealthComponentReportPayload",
  "type": "object",
  "x-sinex-event-type": "health.component_report",
  "x-sinex-source": "health-automaton",
  "x-sinex-version": "1.0.0"
}
