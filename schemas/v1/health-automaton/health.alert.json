{
  "$defs": {
    "ComponentHealthStatus": {
      "description": "Health status for a system component (health automaton)",
      "enum": [
        "Healthy",
        "Warning",
        "Critical",
        "Unknown"
      ],
      "type": "string"
    },
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Health alert for unhealthy components",
  "properties": {
    "alert_level": {
      "type": "string"
    },
    "alert_type": {
      "type": "string"
    },
    "component_name": {
      "type": "string"
    },
    "current_status": {
      "$ref": "#/$defs/ComponentHealthStatus"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "last_seen": {
      "$ref": "#/$defs/DateTime"
    },
    "minutes_since_update": {
      "format": "int64",
      "type": "integer"
    },
    "recent_metrics": {
      "additionalProperties": {
        "format": "double",
        "type": "number"
      },
      "type": "object"
    }
  },
  "required": [
    "alert_type",
    "component_name",
    "alert_level",
    "last_seen",
    "minutes_since_update",
    "current_status",
    "recent_metrics",
    "generated_at"
  ],
  "title": "HealthAlertPayload",
  "type": "object",
  "x-sinex-event-type": "health.alert",
  "x-sinex-source": "health-automaton",
  "x-sinex-version": "1.0.0"
}
