{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ComponentHealthStatus": {
      "description": "Health status for a system component (health automaton)",
      "enum": [
        "Healthy",
        "Warning",
        "Critical",
        "Unknown"
      ],
      "type": "string"
    }
  },
  "description": "Health alert for unhealthy components",
  "properties": {
    "alert_level": {
      "type": "string"
    },
    "alert_type": {
      "type": "string"
    },
    "component_name": {
      "type": "string"
    },
    "current_status": {
      "$ref": "#/definitions/ComponentHealthStatus"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "last_seen": {
      "format": "date-time",
      "type": "string"
    },
    "minutes_since_update": {
      "format": "int64",
      "type": "integer"
    },
    "recent_metrics": {
      "additionalProperties": {
        "format": "double",
        "type": "number"
      },
      "type": "object"
    }
  },
  "required": [
    "alert_level",
    "alert_type",
    "component_name",
    "current_status",
    "generated_at",
    "last_seen",
    "minutes_since_update",
    "recent_metrics"
  ],
  "title": "HealthAlertPayload",
  "type": "object"
}