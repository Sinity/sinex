{
  "$defs": {
    "ScanType": {
      "description": "Type of system scan",
      "oneOf": [
        {
          "const": "full",
          "description": "Full system scan",
          "type": "string"
        },
        {
          "const": "incremental",
          "description": "Incremental scan (only changes)",
          "type": "string"
        },
        {
          "const": "targeted",
          "description": "Targeted scan of specific paths/resources",
          "type": "string"
        },
        {
          "const": "discovery",
          "description": "Initial discovery scan",
          "type": "string"
        },
        {
          "const": "quick",
          "description": "Quick health check scan",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Emitted when a system scan kicks off.",
  "properties": {
    "options": {
      "additionalProperties": true,
      "type": "object"
    },
    "scan_type": {
      "$ref": "#/$defs/ScanType"
    },
    "target": {
      "type": "string"
    }
  },
  "required": [
    "scan_type",
    "target",
    "options"
  ],
  "title": "ScanStartedPayload",
  "type": "object",
  "x-sinex-event-type": "scan.started",
  "x-sinex-source": "system",
  "x-sinex-version": "1.0.0"
}
