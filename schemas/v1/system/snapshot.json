{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "active_watchers": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "dbus_enabled": {
      "type": "boolean"
    },
    "journal_enabled": {
      "type": "boolean"
    },
    "snapshot_time": {
      "$ref": "#/$defs/DateTime"
    },
    "systemd_enabled": {
      "type": "boolean"
    },
    "udev_enabled": {
      "type": "boolean"
    }
  },
  "required": [
    "active_watchers",
    "dbus_enabled",
    "journal_enabled",
    "udev_enabled",
    "systemd_enabled",
    "snapshot_time"
  ],
  "title": "SystemSnapshotPayload",
  "type": "object",
  "x-sinex-event-type": "snapshot",
  "x-sinex-source": "system",
  "x-sinex-version": "1.0.0"
}
