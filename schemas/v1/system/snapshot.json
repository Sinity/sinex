  "properties": {
    "active_watchers": {
      "format": "uint",
      "minimum": 0.0,
      "type": "integer"
    },
    "dbus_enabled": {
      "type": "boolean"
    },
    "journal_enabled": {
      "type": "boolean"
    },
    "snapshot_time": {
      "format": "date-time",
      "type": "string"
    },
    "systemd_enabled": {
      "type": "boolean"
    },
    "udev_enabled": {
      "type": "boolean"
    }
  },
  "required": [
