        "is_local": {
          "type": "boolean"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "tier": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "provider",
        "model",
        "is_local"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Durable routing policy registry entry.",
  "properties": {
