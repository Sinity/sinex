    },
    "policy_id": {
      "type": "string"
    },
    "privacy_policy_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "prompt_id": {
      "type": "string"
    },
    "prompt_version": {
      "type": "string"
    },
    "replay_policy": {
      "type": "string"
    },
    "task_kind": {
      "type": "string"
    }
  },
  "required": [
    "policy_id",
    "task_kind",
    "prompt_id",
    "prompt_version",
    "fallback_order",
    "replay_policy",
    "active"
  ],
  "title": "LlmRoutingPolicyRegisteredPayload",
  "type": "object",
