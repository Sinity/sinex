{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Workflow pattern detection",
  "properties": {
    "analysis_type": {
      "type": "string"
    },
    "frequency": {
      "format": "uint",
      "minimum": 0.0,
      "type": "integer"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "pattern": {
      "type": "string"
    },
    "pattern_type": {
      "type": "string"
    }
  },
  "required": [
    "analysis_type",
    "frequency",
    "generated_at",
    "pattern",
    "pattern_type"
  ],
  "title": "PKMWorkflowPatternPayload",
  "type": "object"
}