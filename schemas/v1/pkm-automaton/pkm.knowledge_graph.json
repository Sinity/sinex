{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Knowledge graph relationships",
  "properties": {
    "analysis_type": {
      "type": "string"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "graph_density": {
      "format": "double",
      "type": "number"
    },
    "relationships": {
      "items": true,
      "type": "array"
    },
    "total_nodes": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "total_relationships": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "analysis_type",
    "total_nodes",
    "total_relationships",
    "relationships",
    "graph_density",
    "generated_at"
  ],
  "title": "PKMKnowledgeGraphPayload",
  "type": "object",
  "x-sinex-event-type": "pkm.knowledge_graph",
  "x-sinex-source": "pkm-automaton",
  "x-sinex-version": "1.0.0"
}
