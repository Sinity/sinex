{
  "$defs": {
    "ActivitySourceKind": {
      "enum": [
        "unknown",
        "window",
        "browser",
        "terminal"
      ],
      "type": "string"
    },
    "ActivityWindowCloseReason": {
      "enum": [
        "gap",
        "max_duration",
        "max_event_count"
      ],
      "type": "string"
    },
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Completed bounded activity window derived from trusted activity signals.",
  "properties": {
    "activity_source_counts": {
      "additionalProperties": false,
      "properties": {
        "browser": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "terminal": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "unknown": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "window": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "activity_sources": {
      "items": {
        "$ref": "#/$defs/ActivitySourceKind"
      },
      "type": "array"
    },
    "close_reason": {
      "$ref": "#/$defs/ActivityWindowCloseReason"
    },
    "duration_secs": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "event_count": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "primary_source": {
      "$ref": "#/$defs/ActivitySourceKind"
    },
    "source_count": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "sources": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "window_end": {
      "$ref": "#/$defs/DateTime"
    },
    "window_id": {
      "type": "string"
    },
    "window_start": {
      "$ref": "#/$defs/DateTime"
    }
  },
  "required": [
    "window_id",
    "window_start",
    "window_end",
    "duration_secs",
    "event_count",
    "source_count",
    "sources",
    "activity_sources",
    "activity_source_counts",
    "primary_source",
    "close_reason"
  ],
  "title": "ActivityWindowSummaryPayload",
  "type": "object",
  "x-sinex-event-type": "activity.window.summary",
  "x-sinex-source": "derived.activity-window",
  "x-sinex-version": "1.0.0"
}
