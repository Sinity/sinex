{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "TerminalType": {
      "description": "Terminal/shell type",
      "oneOf": [
        {
          "const": "kitty",
          "description": "Kitty terminal",
          "type": "string"
        },
        {
          "const": "alacritty",
          "description": "Alacritty terminal",
          "type": "string"
        },
        {
          "const": "foot",
          "description": "Foot terminal",
          "type": "string"
        },
        {
          "const": "wezterm",
          "description": "`WezTerm`",
          "type": "string"
        },
        {
          "const": "iterm2",
          "description": "iTerm2",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Generic/unknown terminal",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "chunk_count": {
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "cwd": {
      "type": "string"
    },
    "git_annex_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "git_annex_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "has_ansi_codes": {
      "type": "boolean"
    },
    "includes_screen": {
      "type": "boolean"
    },
    "is_chunked": {
      "type": "boolean"
    },
    "scrollback_chunks": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "scrollback_lines": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "scrollback_size_bytes": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "scrollback_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "terminal_type": {
      "$ref": "#/$defs/TerminalType"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "window_id": {
      "type": "string"
    },
    "window_title": {
      "type": "string"
    }
  },
  "required": [
    "window_id",
    "terminal_type",
    "cwd",
    "window_title",
    "scrollback_lines",
    "scrollback_size_bytes",
    "is_chunked",
    "includes_screen",
    "has_ansi_codes",
    "timestamp"
  ],
  "title": "ShellOutputCapturedPayload",
  "type": "object",
  "x-sinex-event-type": "shell.output_captured",
  "x-sinex-source": "shell.scrollback",
  "x-sinex-version": "1.0.0"
}
