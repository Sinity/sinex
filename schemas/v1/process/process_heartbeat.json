{
  "$id": "https://sinex.io/schemas/v1/process/process_heartbeat.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "cpu_percent": {
      "format": "float",
      "type": "number"
    },
    "custom_metrics": {
      "additionalProperties": true,
      "type": "object"
    },
    "errors_count": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "events_processed": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "health_status": {
      "type": "string"
    },
    "memory_mb": {
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    },
    "process_name": {
      "type": "string"
    },
    "uptime_seconds": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "cpu_percent",
    "custom_metrics",
    "errors_count",
    "events_processed",
    "health_status",
    "memory_mb",
    "process_name",
    "uptime_seconds",
    "version"
  ],
  "title": "ProcessHeartbeatPayload",
  "type": "object"
}