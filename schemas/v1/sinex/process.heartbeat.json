{
  "$defs": {
    "ProcessStatus": {
      "description": "Strongly typed status for process heartbeat payloads",
      "enum": [
        "healthy",
        "degraded",
        "failed"
      ],
      "type": "string"
    },
    "SequenceNumber": {
      "description": "Sequence number newtype for ordering.",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "metrics": {
      "description": "Optional metrics collected from `MetricsProviders`"
    },
    "sequence": {
      "$ref": "#/$defs/SequenceNumber",
      "description": "Sequence number of this heartbeat (increments each emission)"
    },
    "source": {
      "description": "Name of the service/process emitting the heartbeat",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ProcessStatus",
      "description": "Status of the process"
    }
  },
  "required": [
    "source",
    "sequence",
    "status"
  ],
  "title": "ProcessHeartbeatPayload",
  "type": "object",
  "x-sinex-event-type": "process.heartbeat",
  "x-sinex-source": "sinex",
  "x-sinex-version": "1.0.0"
}
