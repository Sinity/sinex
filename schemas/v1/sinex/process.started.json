{
  "$defs": {
    "NodeType": {
      "description": "Type of node in the system\n\n`Display` rendering maps to `core.manifests.manifest_type`. The\n`#[derive(DbCheck)]` declaration below is the source of truth for the\nDB `CHECK` constraint: bumping `version` ships a rename without manual\nmigration. See issue #1236.",
      "oneOf": [
        {
          "const": "ingestor",
          "description": "Ingestor node (captures events from external sources)",
          "type": "string"
        },
        {
          "const": "automaton",
          "description": "Automaton node (processes events and generates derived data)",
          "type": "string"
        },
        {
          "const": "service",
          "description": "Service node (provides API endpoints)",
          "type": "string"
        }
      ]
    },
    "ProcessId": {
      "description": "Unix process ID newtype.",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "config": true,
    "pid": {
      "$ref": "#/$defs/ProcessId"
    },
    "process_name": {
      "type": "string"
    },
    "process_type": {
      "$ref": "#/$defs/NodeType"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "process_name",
    "process_type",
    "pid",
    "version",
    "config"
  ],
  "title": "ProcessStartedPayload",
  "type": "object",
  "x-sinex-event-type": "process.started",
  "x-sinex-source": "sinex",
  "x-sinex-version": "1.0.0"
}
