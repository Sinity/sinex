{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Component health status change\n\nEmitted when a component's health status changes (healthy -> degraded, etc.)",
  "properties": {
    "component": {
      "description": "Component name",
      "type": "string"
    },
    "context": {
      "description": "Additional context"
    },
    "current_status": {
      "description": "Current status",
      "type": "string"
    },
    "previous_status": {
      "description": "Previous status",
      "type": "string"
    },
    "reason": {
      "description": "Reason for status change",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "component",
    "previous_status",
    "current_status"
  ],
  "title": "HealthStatusPayload",
  "type": "object",
  "x-sinex-event-type": "health.status",
  "x-sinex-source": "sinex",
  "x-sinex-version": "1.0.0"
}
