{
  "$id": "https://sinex.io/schemas/v1/sinex/satellite_heartbeat.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "service_name": {
      "type": "string",
      "description": "Name of the satellite service emitting the heartbeat"
    },
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "failed"],
      "description": "Current health status of the service"
    },
    "events_processed": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of events processed since last heartbeat"
    },
    "uptime_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Service uptime in seconds"
    },
    "memory_usage_mb": {
      "type": "integer",
      "minimum": 0,
      "description": "Memory usage in megabytes"
    },
    "cpu_usage_percent": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 100.0,
      "description": "CPU usage percentage"
    },
    "errors_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of errors since last heartbeat"
    },
    "last_error_message": {
      "type": ["string", "null"],
      "description": "Last error message if any"
    },
    "version": {
      "type": "string",
      "description": "Binary version of the service"
    },
    "git_hash": {
      "type": "string",
      "description": "Git commit hash of the service build"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when heartbeat was generated"
    },
    "metadata": {
      "type": ["object", "null"],
      "description": "Additional service-specific metadata"
    }
  },
  "required": [
    "service_name",
    "status",
    "events_processed",
    "uptime_seconds",
    "memory_usage_mb",
    "cpu_usage_percent",
    "errors_count",
    "version",
    "git_hash",
    "timestamp"
  ],
  "title": "SatelliteHeartbeatPayload",
  "type": "object"
}