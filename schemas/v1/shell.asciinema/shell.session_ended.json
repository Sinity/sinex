{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "TerminalType": {
      "description": "Terminal/shell type",
      "oneOf": [
        {
          "const": "kitty",
          "description": "Kitty terminal",
          "type": "string"
        },
        {
          "const": "alacritty",
          "description": "Alacritty terminal",
          "type": "string"
        },
        {
          "const": "foot",
          "description": "Foot terminal",
          "type": "string"
        },
        {
          "const": "wezterm",
          "description": "`WezTerm`",
          "type": "string"
        },
        {
          "const": "iterm2",
          "description": "iTerm2",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Generic/unknown terminal",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "content_key": true,
    "content_store_path": true,
    "duration_seconds": {
      "format": "double",
      "type": "number"
    },
    "end_time": {
      "$ref": "#/$defs/DateTime"
    },
    "event_count": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "file_size_bytes": {
      "format": "uint64",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "recording_file": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "terminal_id": {
      "type": "string"
    },
    "terminal_type": {
      "$ref": "#/$defs/TerminalType"
    }
  },
  "required": [
    "session_id",
    "terminal_type",
    "terminal_id",
    "end_time",
    "duration_seconds",
    "event_count",
    "recording_file"
  ],
  "title": "AsciinemaSessionEndedPayload",
  "type": "object",
  "x-sinex-event-type": "shell.session_ended",
  "x-sinex-source": "shell.asciinema",
  "x-sinex-version": "1.0.0"
}
