{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Node event processing statistics\n\nAddresses Issues 24, 29: Event Processing Metrics",
  "properties": {
    "avg_latency_ms": {
      "description": "Average processing latency (ms)",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "error_count": {
      "description": "Errors encountered",
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "events_dropped": {
      "description": "Events dropped (channel full, errors)",
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "events_processed": {
      "description": "Events processed since last report",
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "node_type": {
      "description": "Node type (fs-ingestor, terminal-ingestor, etc.)",
      "type": "string"
    },
    "queue_depth": {
      "description": "Current queue depth",
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    }
  },
  "required": [
    "error_count",
    "events_dropped",
    "events_processed",
    "node_type",
    "queue_depth"
  ],
  "title": "NodeProcessingStatsPayload",
  "type": "object"
}