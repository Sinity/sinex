{
  "$defs": {
    "ExitCode": {
      "description": "Process exit code newtype.\n\nDistinguishes exit codes from other i32 values. Unix convention:\n- 0: success\n- 1-125: application-defined errors\n- 126: command not executable\n- 127: command not found\n- 128+N: killed by signal N",
      "format": "int32",
      "type": "integer"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Atuin command completion payload.",
  "properties": {
    "atuin_id": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "duration_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "exit_status": {
      "$ref": "#/$defs/ExitCode"
    },
    "hostname": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "shell": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "working_directory": {
      "type": "string"
    }
  },
  "required": [
    "command",
    "working_directory",
    "exit_status",
    "duration_ms",
    "hostname",
    "username",
    "shell",
    "atuin_id",
    "session_id"
  ],
  "title": "AtuinCommandCompletedPayload",
  "type": "object",
  "x-sinex-event-type": "command.completed",
  "x-sinex-source": "shell.atuin",
  "x-sinex-version": "1.0.0"
}
