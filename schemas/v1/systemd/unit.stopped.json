{
  "$defs": {
    "ExitCode": {
      "description": "Process exit code newtype.\n\nDistinguishes exit codes from other i32 values. Unix convention:\n- 0: success\n- 1-125: application-defined errors\n- 126: command not executable\n- 127: command not found\n- 128+N: killed by signal N",
      "format": "int32",
      "type": "integer"
    },
    "SystemdActiveState": {
      "description": "Systemd unit active state",
      "oneOf": [
        {
          "const": "active",
          "description": "Unit is active",
          "type": "string"
        },
        {
          "const": "reloading",
          "description": "Unit is reloading",
          "type": "string"
        },
        {
          "const": "inactive",
          "description": "Unit is inactive",
          "type": "string"
        },
        {
          "const": "failed",
          "description": "Unit failed",
          "type": "string"
        },
        {
          "const": "activating",
          "description": "Unit is activating",
          "type": "string"
        },
        {
          "const": "deactivating",
          "description": "Unit is deactivating",
          "type": "string"
        },
        {
          "const": "maintenance",
          "description": "Unit is in maintenance",
          "type": "string"
        }
      ]
    },
    "SystemdUnitType": {
      "description": "Systemd unit type",
      "oneOf": [
        {
          "const": "service",
          "description": "Service unit",
          "type": "string"
        },
        {
          "const": "socket",
          "description": "Socket unit",
          "type": "string"
        },
        {
          "const": "target",
          "description": "Target unit",
          "type": "string"
        },
        {
          "const": "device",
          "description": "Device unit",
          "type": "string"
        },
        {
          "const": "mount",
          "description": "Mount unit",
          "type": "string"
        },
        {
          "const": "automount",
          "description": "Automount unit",
          "type": "string"
        },
        {
          "const": "timer",
          "description": "Timer unit",
          "type": "string"
        },
        {
          "const": "swap",
          "description": "Swap unit",
          "type": "string"
        },
        {
          "const": "path",
          "description": "Path unit",
          "type": "string"
        },
        {
          "const": "slice",
          "description": "Slice unit",
          "type": "string"
        },
        {
          "const": "scope",
          "description": "Scope unit",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Other unit type",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "active_state": {
      "$ref": "#/$defs/SystemdActiveState"
    },
    "exit_code": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExitCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "sub_state": {
      "type": "string"
    },
    "unit_name": {
      "type": "string"
    },
    "unit_type": {
      "$ref": "#/$defs/SystemdUnitType"
    }
  },
  "required": [
    "unit_name",
    "unit_type",
    "active_state",
    "sub_state"
  ],
  "title": "SystemdUnitStoppedPayload",
  "type": "object",
  "x-sinex-event-type": "unit.stopped",
  "x-sinex-source": "systemd",
  "x-sinex-version": "1.0.0"
}
