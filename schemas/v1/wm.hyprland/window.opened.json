{
  "$defs": {
    "WindowGeometry": {
      "properties": {
        "height": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "width": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "x": {
          "format": "int32",
          "type": "integer"
        },
        "y": {
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "floating": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "geometry": {
      "anyOf": [
        {
          "$ref": "#/$defs/WindowGeometry"
        },
        {
          "type": "null"
        }
      ]
    },
    "monitor_id": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "window_class": {
      "type": "string"
    },
    "window_id": {
      "type": "string"
    },
    "window_title": {
      "type": "string"
    },
    "workspace_id": {
      "description": "Hyprland sends workspace_id as a string; parsed to i32.",
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "workspace_name": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "window_id",
    "window_class",
    "window_title"
  ],
  "title": "HyprlandWindowOpenedPayload",
  "type": "object",
  "x-sinex-event-type": "window.opened",
  "x-sinex-source": "wm.hyprland",
  "x-sinex-version": "1.0.0"
}
