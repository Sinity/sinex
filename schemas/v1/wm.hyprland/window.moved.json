{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Hyprland `movewindow` event: address + destination workspace.",
  "properties": {
    "window_id": {
      "type": "string"
    },
    "workspace_id": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "workspace_name": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "window_id"
  ],
  "title": "HyprlandWindowMovedPayload",
  "type": "object",
  "x-sinex-event-type": "window.moved",
  "x-sinex-source": "wm.hyprland",
  "x-sinex-version": "1.0.0"
}
