{
  "$id": "https://sinex.io/schemas/v1/scan/scan_completed.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Ulid": {
      "description": "A Universally Unique Lexicographically Sortable Identifier (ULID)",
      "maxLength": 26,
      "minLength": 26,
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    }
  },
  "properties": {
    "blob_id": {
      "anyOf": [
        {
          "$ref": "#/definitions/Ulid"
        },
        {
          "type": "null"
        }
      ]
    },
    "content_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "duration_ms": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "events_generated": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "git_annex_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "scan_id": {
      "type": "string"
    },
    "scanner": {
      "type": "string"
    },
    "source_stats": {
      "additionalProperties": {
        "format": "uint64",
        "minimum": 0.0,
        "type": "integer"
      },
      "type": "object"
    },
    "time_range": {
      "items": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "format": "date-time",
          "type": "string"
        }
      ],
      "maxItems": 2,
      "minItems": 2,
      "type": [
        "array",
        "null"
      ]
    },
    "was_duplicate": {
      "type": "boolean"
    }
  },
  "required": [
    "duration_ms",
    "events_generated",
    "scan_id",
    "scanner",
    "source_stats",
    "was_duplicate"
  ],
  "title": "ScanCompletedPayload",
  "type": "object"
}