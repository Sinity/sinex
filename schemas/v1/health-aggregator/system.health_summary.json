{
  "$defs": {
    "ComponentHealth": {
      "properties": {
        "events_processed": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "git_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_heartbeat": {
          "$ref": "#/$defs/DateTime"
        },
        "memory_usage_mb": {
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        },
        "service_name": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/SystemHealthStatus"
        },
        "uptime_seconds": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "service_name",
        "status",
        "last_heartbeat"
      ],
      "type": "object"
    },
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "SystemHealthStatus": {
      "enum": [
        "healthy",
        "degraded",
        "failed",
        "missing"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "components": {
      "additionalProperties": {
        "$ref": "#/$defs/ComponentHealth"
      },
      "type": "object"
    },
    "degraded_components": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "failed_components": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "healthy_components": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "last_updated": {
      "$ref": "#/$defs/DateTime"
    },
    "missing_components": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "overall_status": {
      "$ref": "#/$defs/SystemHealthStatus"
    },
    "total_components": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "overall_status",
    "healthy_components",
    "degraded_components",
    "failed_components",
    "missing_components",
    "total_components",
    "last_updated",
    "components"
  ],
  "title": "SystemHealthSummaryPayload",
  "type": "object",
  "x-sinex-event-type": "system.health_summary",
  "x-sinex-source": "health-aggregator",
  "x-sinex-version": "1.0.0"
}
