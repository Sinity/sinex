{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Kitty terminal session end event.",
  "properties": {
    "duration_seconds": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "exit_code": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "tab_id": {
      "type": "string"
    },
    "window_id": {
      "type": "string"
    }
  },
  "required": [
    "duration_seconds",
    "tab_id",
    "window_id"
  ],
  "title": "KittySessionEndedPayload",
  "type": "object"
}