{
  "$defs": {
    "RecordedPath": {
      "description": "A path recorded from observational data (filesystem events, shell CWDs). Preserved verbatim except null bytes.",
      "type": "string"
    },
    "ShellName": {
      "description": "A shell name (e.g., `bash`, `zsh`, `fish`)",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Kitty terminal session start.",
  "properties": {
    "env_vars": {
      "additionalProperties": {
        "type": "string"
      },
      "type": [
        "object",
        "null"
      ]
    },
    "shell_type": {
      "$ref": "#/$defs/ShellName"
    },
    "tab_id": {
      "type": "string"
    },
    "window_id": {
      "type": "string"
    },
    "working_directory": {
      "$ref": "#/$defs/RecordedPath"
    }
  },
  "required": [
    "window_id",
    "tab_id",
    "shell_type",
    "working_directory"
  ],
  "title": "KittySessionStartedPayload",
  "type": "object",
  "x-sinex-event-type": "session.started",
  "x-sinex-source": "terminal.kitty",
  "x-sinex-version": "1.0.0"
}
