{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Shell history command imported event.",
  "properties": {
    "command": {
      "type": "string"
    },
    "line_number": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "shell_type": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "timestamp": {
      "anyOf": [
        {
          "$ref": "#/$defs/DateTime"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "command",
    "shell_type",
    "source_file"
  ],
  "title": "HistoryCommandImportedPayload",
  "type": "object",
  "x-sinex-event-type": "command.imported",
  "x-sinex-source": "shell.history",
  "x-sinex-version": "1.0.0"
}
