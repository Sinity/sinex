{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Shell history command imported event.",
  "properties": {
    "command": {
      "type": "string"
    },
    "line_number": {
      "format": "uint32",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    },
    "shell_type": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "command",
    "shell_type",
    "source_file"
  ],
  "title": "HistoryCommandImportedPayload",
  "type": "object"
}