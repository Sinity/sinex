          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "entity_confidence_changed": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "entity_merge": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "entity_missing": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "entity_new": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "entity_split": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "relation_added": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "relation_predicate_changed": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "relation_removed": {
          "format": "uint",
          "minimum": 0,
