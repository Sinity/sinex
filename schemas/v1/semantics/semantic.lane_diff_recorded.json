    "baseline_lane_id": {
      "format": "uuid",
      "type": "string"
    },
    "candidate_lane_id": {
      "format": "uuid",
      "type": "string"
    },
    "created_at": {
      "$ref": "#/$defs/DateTime"
    },
    "diff_id": {
      "format": "uuid",
      "type": "string"
    },
    "diff_kind": {
      "type": "string"
    },
    "operation_id": {
      "format": "uuid",
      "type": [
        "string",
        "null"
      ]
    },
    "report": {
