{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "DeviceType": {
      "description": "Device/subsystem type",
      "oneOf": [
        {
          "const": "usb",
          "description": "USB device",
          "type": "string"
        },
        {
          "const": "storage",
          "description": "Storage device (disk, partition)",
          "type": "string"
        },
        {
          "const": "network",
          "description": "Network interface",
          "type": "string"
        },
        {
          "const": "input",
          "description": "Input device (keyboard, mouse)",
          "type": "string"
        },
        {
          "const": "audio",
          "description": "Audio device",
          "type": "string"
        },
        {
          "const": "video",
          "description": "Video/display device",
          "type": "string"
        },
        {
          "const": "bluetooth",
          "description": "Bluetooth device",
          "type": "string"
        },
        {
          "const": "battery",
          "description": "Battery",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Other/unknown device type",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "D-Bus announcement for a newly connected device.",
  "properties": {
    "device_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "device_path": {
      "type": "string"
    },
    "device_type": {
      "$ref": "#/$defs/DeviceType"
    },
    "event_type": {
      "type": "string"
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "properties": {
      "additionalProperties": true,
      "type": "object"
    },
    "serial": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "vendor": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "device_type",
    "event_type",
    "device_path",
    "properties",
    "timestamp"
  ],
  "title": "DbusDeviceConnectedPayload",
  "type": "object",
  "x-sinex-event-type": "device.connected",
  "x-sinex-source": "dbus",
  "x-sinex-version": "1.0.0"
}
