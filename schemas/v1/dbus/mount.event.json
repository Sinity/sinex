{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "MountEventType": {
      "description": "Mount/unmount event type",
      "oneOf": [
        {
          "const": "mounted",
          "description": "Filesystem mounted",
          "type": "string"
        },
        {
          "const": "unmounted",
          "description": "Filesystem unmounted",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "device": {
      "type": "string"
    },
    "event_type": {
      "$ref": "#/$defs/MountEventType"
    },
    "filesystem": {
      "type": "string"
    },
    "label": {
      "type": [
        "string",
        "null"
      ]
    },
    "mount_point": {
      "type": "string"
    },
    "size_bytes": {
      "format": "uint64",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "uuid": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "event_type",
    "device",
    "mount_point",
    "filesystem",
    "timestamp"
  ],
  "title": "DbusMountEventPayload",
  "type": "object",
  "x-sinex-event-type": "mount.event",
  "x-sinex-source": "dbus",
  "x-sinex-version": "1.0.0"
}
