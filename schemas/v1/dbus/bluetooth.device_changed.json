{
  "$defs": {
    "BluetoothEventType": {
      "description": "Bluetooth device event type",
      "oneOf": [
        {
          "const": "connected",
          "description": "Device connected",
          "type": "string"
        },
        {
          "const": "disconnected",
          "description": "Device disconnected",
          "type": "string"
        },
        {
          "const": "paired",
          "description": "Device paired",
          "type": "string"
        },
        {
          "const": "unpaired",
          "description": "Device unpaired",
          "type": "string"
        },
        {
          "const": "discovered",
          "description": "Device discovered",
          "type": "string"
        },
        {
          "const": "properties_changed",
          "description": "Device properties changed",
          "type": "string"
        }
      ]
    },
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "connected": {
      "type": "boolean"
    },
    "device_address": {
      "type": "string"
    },
    "device_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "device_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_type": {
      "$ref": "#/$defs/BluetoothEventType"
    },
    "paired": {
      "type": "boolean"
    },
    "rssi": {
      "format": "int16",
      "maximum": 32767,
      "minimum": -32768,
      "type": [
        "integer",
        "null"
      ]
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "trusted": {
      "type": "boolean"
    }
  },
  "required": [
    "event_type",
    "device_address",
    "connected",
    "paired",
    "trusted",
    "timestamp"
  ],
  "title": "DbusBluetoothDeviceChangedPayload",
  "type": "object",
  "x-sinex-event-type": "bluetooth.device_changed",
  "x-sinex-source": "dbus",
  "x-sinex-version": "1.0.0"
}
