{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Desktop notification dispatched over D-Bus.",
  "properties": {
    "actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "app_name": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "hints": {
      "additionalProperties": true,
      "type": "object"
    },
    "summary": {
      "type": "string"
    },
    "timeout": {
      "format": "int32",
      "type": "integer"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "urgency": {
      "format": "uint8",
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "app_name",
    "summary",
    "body",
    "urgency",
    "timeout",
    "actions",
    "hints",
    "timestamp"
  ],
  "title": "DbusNotificationSentPayload",
  "type": "object",
  "x-sinex-event-type": "notification.sent",
  "x-sinex-source": "dbus",
  "x-sinex-version": "1.0.0"
}
