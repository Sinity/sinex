{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Desktop notification dispatched over D-Bus.",
  "properties": {
    "actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "app_name": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "hints": {
      "additionalProperties": true,
      "type": "object"
    },
    "summary": {
      "type": "string"
    },
    "timeout": {
      "format": "int32",
      "type": "integer"
    },
    "timestamp": {
      "type": "string"
    },
    "urgency": {
      "format": "uint8",
      "minimum": 0.0,
      "type": "integer"
    }
  },
  "required": [
    "actions",
    "app_name",
    "body",
    "hints",
    "summary",
    "timeout",
    "timestamp",
    "urgency"
  ],
  "title": "DbusNotificationSentPayload",
  "type": "object"
}