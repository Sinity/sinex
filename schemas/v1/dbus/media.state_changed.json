{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "LoopStatus": {
      "description": "Media loop/repeat status",
      "oneOf": [
        {
          "const": "none",
          "description": "No looping",
          "type": "string"
        },
        {
          "const": "track",
          "description": "Loop current track",
          "type": "string"
        },
        {
          "const": "playlist",
          "description": "Loop playlist",
          "type": "string"
        }
      ]
    },
    "PlaybackStatus": {
      "description": "Media playback status",
      "oneOf": [
        {
          "const": "playing",
          "description": "Currently playing",
          "type": "string"
        },
        {
          "const": "paused",
          "description": "Paused",
          "type": "string"
        },
        {
          "const": "stopped",
          "description": "Stopped",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Media player metadata snapshot extracted from D-Bus.",
  "properties": {
    "album": {
      "type": [
        "string",
        "null"
      ]
    },
    "album_artist": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "art_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "artist": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "can_go_next": {
      "type": "boolean"
    },
    "can_go_previous": {
      "type": "boolean"
    },
    "can_pause": {
      "type": "boolean"
    },
    "can_play": {
      "type": "boolean"
    },
    "can_seek": {
      "type": "boolean"
    },
    "length": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "loop_status": {
      "anyOf": [
        {
          "$ref": "#/$defs/LoopStatus"
        },
        {
          "type": "null"
        }
      ]
    },
    "player": {
      "type": "string"
    },
    "player_instance": {
      "type": "string"
    },
    "position": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "shuffle": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "status": {
      "$ref": "#/$defs/PlaybackStatus"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "track_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "track_number": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "volume": {
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    }
  },
  "required": [
    "player",
    "player_instance",
    "status",
    "can_go_next",
    "can_go_previous",
    "can_play",
    "can_pause",
    "can_seek",
    "timestamp"
  ],
  "title": "DbusMediaStateChangedPayload",
  "type": "object",
  "x-sinex-event-type": "media.state_changed",
  "x-sinex-source": "dbus",
  "x-sinex-version": "1.0.0"
}
