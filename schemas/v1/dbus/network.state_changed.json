    },
    "interface": {
      "type": "string"
    },
    "ip_address": {
      "type": [
        "string",
        "null"
      ]
    },
    "ssid": {
      "type": [
        "string",
        "null"
      ]
    },
    "state": {
      "$ref": "#/$defs/NetworkState"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    }
