{
  "$defs": {
    "CommandText": {
      "description": "A command line text",
      "type": "string"
    },
    "ExitCode": {
      "description": "Process exit code newtype.\n\nDistinguishes exit codes from other i32 values. Unix convention:\n- 0: success\n- 1-125: application-defined errors\n- 126: command not executable\n- 127: command not found\n- 128+N: killed by signal N",
      "format": "int32",
      "type": "integer"
    },
    "ProcessId": {
      "description": "Unix process ID newtype.",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "RecordedPath": {
      "description": "A path recorded from observational data (filesystem events, shell CWDs). Preserved verbatim except null bytes.",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Kitty command completion event.",
  "properties": {
    "command": {
      "$ref": "#/$defs/CommandText"
    },
    "duration_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "error_output": {
      "type": [
        "string",
        "null"
      ]
    },
    "exit_status": {
      "$ref": "#/$defs/ExitCode"
    },
    "kitty_tab_id": {
      "type": "string"
    },
    "kitty_window_id": {
      "type": "string"
    },
    "output_lines": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "shell_pid": {
      "$ref": "#/$defs/ProcessId"
    },
    "working_directory": {
      "$ref": "#/$defs/RecordedPath"
    }
  },
  "required": [
    "command",
    "working_directory",
    "exit_status",
    "duration_ms",
    "shell_pid",
    "kitty_window_id",
    "kitty_tab_id"
  ],
  "title": "KittyCommandCompletedPayload",
  "type": "object",
  "x-sinex-event-type": "command.completed",
  "x-sinex-source": "shell.kitty",
  "x-sinex-version": "1.0.0"
}
