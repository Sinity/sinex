      "type": "string"
    }
  },
  "required": [
    "kitty_tab_id",
    "kitty_window_id",
    "tab_title",
    "tab_index",
    "focus_timestamp"
  ],
  "title": "KittyTabFocusedPayload",
  "type": "object",
  "x-sinex-event-type": "tab.focused",
