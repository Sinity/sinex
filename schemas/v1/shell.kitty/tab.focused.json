{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "focus_timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "kitty_tab_id": {
      "type": "string"
    },
    "kitty_window_id": {
      "type": "string"
    },
    "previous_tab_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tab_index": {
