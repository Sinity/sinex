{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "raw_material_id": {
      "type": "string"
    },
    "file_format": {
      "type": [
        "string",
        "null"
      ]
    },
    "codec": {
      "type": [
        "string",
        "null"
      ]
    },
    "duration_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "channel_count": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "sample_rate_hz": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "capture_session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_file": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_posture": {
      "type": "string"
    },
    "observed_at": {
      "$ref": "#/$defs/DateTime"
    }
  },
  "required": [
    "raw_material_id",
    "policy_posture",
    "observed_at"
  ],
  "title": "AudioRecordingObservedPayload",
  "type": "object",
  "x-sinex-event-type": "media.audio.recording_observed",
  "x-sinex-source": "media.audio",
  "x-sinex-version": "1.0.0"
}
