        {
          "const": "add",
          "description": "Device added",
          "type": "string"
        },
        {
          "const": "remove",
          "description": "Device removed",
          "type": "string"
        },
        {
          "const": "change",
          "description": "Device changed",
          "type": "string"
        },
        {
          "const": "bind",
          "description": "Driver bound",
          "type": "string"
        },
        {
          "const": "unbind",
          "description": "Driver unbound",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Other action",
          "type": "string"
        }
      ]
    }
