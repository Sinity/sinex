        "type": "string"
      },
      "type": "object"
    },
    "serial": {
      "type": [
        "string",
        "null"
      ]
    },
    "subsystem": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "$ref": "#/$defs/DateTime"
    },
    "vendor": {
      "type": [
        "string",
        "null"
      ]
