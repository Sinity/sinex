          "type": "string"
        },
        {
          "const": "storage",
          "description": "Storage device (disk, partition)",
          "type": "string"
        },
        {
          "const": "network",
          "description": "Network interface",
          "type": "string"
        },
        {
          "const": "input",
          "description": "Input device (keyboard, mouse)",
          "type": "string"
        },
        {
          "const": "audio",
          "description": "Audio device",
          "type": "string"
        },
        {
          "const": "video",
          "description": "Video/display device",
          "type": "string"
        },
        {
          "const": "bluetooth",
          "description": "Bluetooth device",
          "type": "string"
        },
        {
          "const": "battery",
          "description": "Battery",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Other/unknown device type",
          "type": "string"
        }
      ]
    },
    "UdevAction": {
      "description": "udev action type",
