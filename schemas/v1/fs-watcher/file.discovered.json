{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "RecordedPath": {
      "description": "A path recorded from observational data (filesystem events, shell CWDs). Preserved verbatim except null bytes.",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "modified_at": {
      "$ref": "#/$defs/DateTime"
    },
    "path": {
      "$ref": "#/$defs/RecordedPath"
    },
    "permissions": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "size": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "path",
    "size",
    "modified_at"
  ],
  "title": "FileDiscoveredPayload",
  "type": "object",
  "x-sinex-event-type": "file.discovered",
  "x-sinex-source": "fs-watcher",
  "x-sinex-version": "1.0.0"
}
