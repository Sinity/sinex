{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Pattern detection event",
  "properties": {
    "avg_delta_ms": {
      "format": "int64",
      "type": "integer"
    },
    "from_event": {
      "type": "string"
    },
    "last_seen": {
      "anyOf": [
        {
          "$ref": "#/$defs/DateTime"
        },
        {
          "type": "null"
        }
      ]
    },
    "occurrences": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "pattern_type": {
      "type": "string"
    },
    "to_event": {
      "type": "string"
    }
  },
  "required": [
    "pattern_type",
    "from_event",
    "to_event",
    "occurrences",
    "avg_delta_ms"
  ],
  "title": "AnalyticsPatternDetectedPayload",
  "type": "object",
  "x-sinex-event-type": "analytics.pattern.detected",
  "x-sinex-source": "analytics-automaton",
  "x-sinex-version": "1.0.0"
}
