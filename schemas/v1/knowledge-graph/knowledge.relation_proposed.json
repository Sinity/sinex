{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Emitted when a relationship between two entities is detected.\nDownstream automata promote or reject based on confidence thresholds.",
  "properties": {
    "confidence": {
      "format": "double",
      "type": "number"
    },
    "relation_type": {
      "type": "string"
    },
    "source_entity_id": {
      "format": "uuid",
      "type": "string"
    },
    "target_entity_id": {
      "format": "uuid",
      "type": "string"
    }
  },
  "required": [
    "source_entity_id",
    "target_entity_id",
    "relation_type",
    "confidence"
  ],
  "title": "KnowledgeRelationProposedPayload",
  "type": "object",
  "x-sinex-event-type": "knowledge.relation_proposed",
  "x-sinex-source": "knowledge-graph",
  "x-sinex-version": "1.0.0"
}
