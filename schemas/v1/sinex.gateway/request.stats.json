{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Gateway request statistics\n\nAddresses Issue 133: Load Shedding Metrics",
  "properties": {
    "active_connections": {
      "description": "Active connections",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "avg_latency_ms": {
      "description": "Average latency in milliseconds",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "max_latency_ms": {
      "description": "Maximum latency in milliseconds (over the snapshot window)",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "min_latency_ms": {
      "description": "Minimum latency in milliseconds (over the snapshot window)",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "p99_latency_ms": {
      "description": "P99 latency in milliseconds",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "rate_limited_requests": {
      "description": "Requests rate-limited (subset of rejected)",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "rejected_requests": {
      "description": "Requests rejected (rate limited, auth failed, etc.)",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "successful_requests": {
      "description": "Requests successfully processed",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_requests": {
      "description": "Total requests received",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "total_requests",
    "successful_requests",
    "rejected_requests",
    "rate_limited_requests",
    "active_connections"
  ],
  "title": "GatewayRequestStatsPayload",
  "type": "object",
  "x-sinex-event-type": "request.stats",
  "x-sinex-source": "sinex.gateway",
  "x-sinex-version": "1.0.0"
}
