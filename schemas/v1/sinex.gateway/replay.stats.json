{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Replay operation metrics\n\nAddresses Issue 145: Replay Control Metrics",
  "properties": {
    "avg_duration_ms": {
      "description": "Average replay duration (ms)",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "events_affected": {
      "description": "Events affected by replays",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "failed": {
      "description": "Failed replays",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "successful": {
      "description": "Successful replays",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_requests": {
      "description": "Total replay requests",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "total_requests",
    "successful",
    "failed",
    "events_affected"
  ],
  "title": "ReplayStatsPayload",
  "type": "object",
  "x-sinex-event-type": "replay.stats",
  "x-sinex-source": "sinex.gateway",
  "x-sinex-version": "1.0.0"
}
