{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Rate limit event for specific token\n\nIndividual rate limit violations (for audit/debugging)",
  "properties": {
    "limit": {
      "description": "Configured limit",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "method": {
      "description": "Method being called",
      "type": [
        "string",
        "null"
      ]
    },
    "requests_in_window": {
      "description": "Number of requests in current window",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "token_prefix": {
      "description": "Token prefix (first 8 chars for identification without full exposure)",
      "type": "string"
    }
  },
  "required": [
    "token_prefix",
    "requests_in_window",
    "limit"
  ],
  "title": "RateLimitExceededPayload",
  "type": "object",
  "x-sinex-event-type": "rate_limit.exceeded",
  "x-sinex-source": "sinex.gateway",
  "x-sinex-version": "1.0.0"
}
