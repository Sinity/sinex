{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sinex.dev/schemas/v1/processor/processor_registered.json",
  "title": "Processor Registered Event",
  "description": "Event emitted when a processor registers in the manifest",
  "type": "object",
  "properties": {
    "manifest_id": {
      "type": "integer",
      "description": "ID of the processor manifest entry"
    },
    "processor_name": {
      "type": "string",
      "description": "Name of the processor",
      "minLength": 1
    },
    "processor_version": {
      "type": "string",
      "description": "Version of the processor",
      "minLength": 1
    },
    "processor_type": {
      "type": "string", 
      "description": "Type of the processor (e.g., satellite, automaton, ingestor)",
      "minLength": 1
    },
    "hostname": {
      "type": "string",
      "description": "Hostname where the processor is running",
      "minLength": 1
    },
    "start_time": {
      "type": "string",
      "format": "date-time",
      "description": "When the processor started"
    },
    "config": {
      "type": ["object", "null"],
      "description": "Processor configuration data"
    },
    "metadata": {
      "type": ["object", "null"],
      "description": "Additional processor metadata"
    }
  },
  "required": [
    "manifest_id",
    "processor_name",
    "processor_version",
    "processor_type",
    "hostname",
    "start_time"
  ],
  "additionalProperties": false
}