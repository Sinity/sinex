{
  "$defs": {
    "CurationProposalStatus": {
      "description": "Lifecycle state for a proposal record.",
      "enum": [
        "pending",
        "superseded",
        "judged",
        "finalized",
        "expired"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Producer-owned candidate assertion or operation.",
  "properties": {
    "candidate_event_type": {
      "description": "Candidate canonical event type to emit if finalized.",
      "type": "string"
    },
    "candidate_payload": {
      "description": "Candidate canonical payload."
    },
    "candidate_source": {
      "description": "Candidate canonical event source to emit if finalized.",
      "type": "string"
    },
    "confidence": {
      "description": "Confidence in `[0.0, 1.0]`; consumers must not treat it as authority.",
      "format": "double",
      "type": "number"
    },
    "evidence_event_ids": {
      "description": "Parent event evidence used by the producer.",
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "type": "array"
    },
    "evidence_material_ids": {
      "description": "Source material evidence used by the producer.",
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "type": "array"
    },
    "producer": {
      "description": "Producer identifier and version, e.g. `fixture-tagger@1`.",
      "type": "string"
    },
    "proposal_id": {
      "description": "Stable proposal id generated by the producer.",
      "format": "uuid",
      "type": "string"
    },
    "proposal_key": {
      "description": "Replay-stable key for deduplicating regenerated identical candidates.",
      "type": "string"
    },
    "proposal_kind": {
      "description": "Domain-specific kind, e.g. `knowledge.tag_applied` or `task.created`.",
      "type": "string"
    },
    "rationale": {
      "description": "Safe display rationale.",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/CurationProposalStatus"
    },
    "target_ref": {
      "description": "Optional existing object being modified.",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "proposal_id",
    "proposal_key",
    "proposal_kind",
    "candidate_source",
    "candidate_event_type",
    "candidate_payload",
    "producer",
    "confidence",
    "rationale",
    "status"
  ],
  "title": "CurationProposalPayload",
  "type": "object",
  "x-sinex-event-type": "curation.proposal",
  "x-sinex-source": "curation",
  "x-sinex-version": "1.0.0"
}
