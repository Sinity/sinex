{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "SearchIndexTopEntry": {
      "description": "Top search index entry summary",
      "properties": {
        "event_type": {
          "type": "string"
        },
        "keywords": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "search_score": {
          "format": "double",
          "type": "number"
        },
        "timestamp": {
          "$ref": "#/$defs/DateTime"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "event_type",
        "search_score",
        "keywords",
        "timestamp"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Search index built event",
  "properties": {
    "analysis_type": {
      "type": "string"
    },
    "avg_score_by_type": {
      "additionalProperties": {
        "format": "double",
        "type": "number"
      },
      "type": "object"
    },
    "content_type_distribution": {
      "additionalProperties": {
        "format": "uint",
        "minimum": 0,
        "type": "integer"
      },
      "type": "object"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "index_size_limit": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "indexing_window_hours": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "top_entries": {
      "items": {
        "$ref": "#/$defs/SearchIndexTopEntry"
      },
      "type": "array"
    },
    "total_entries": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "analysis_type",
    "total_entries",
    "content_type_distribution",
    "avg_score_by_type",
    "top_entries",
    "index_size_limit",
    "indexing_window_hours",
    "generated_at"
  ],
  "title": "SearchIndexBuiltPayload",
  "type": "object",
  "x-sinex-event-type": "search.index_built",
  "x-sinex-source": "search-automaton",
  "x-sinex-version": "1.0.0"
}
