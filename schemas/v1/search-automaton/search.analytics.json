{
  "$defs": {
    "ContentTypeCount": {
      "description": "Content type count for search analytics",
      "properties": {
        "count": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "event_type": {
          "type": "string"
        }
      },
      "required": [
        "event_type",
        "count"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Search analytics event",
  "properties": {
    "analysis_type": {
      "type": "string"
    },
    "index_size": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "semantic_enabled": {
      "type": "boolean"
    },
    "top_content_types": {
      "items": {
        "$ref": "#/$defs/ContentTypeCount"
      },
      "type": "array"
    }
  },
  "required": [
    "analysis_type",
    "top_content_types",
    "index_size",
    "semantic_enabled"
  ],
  "title": "SearchAnalyticsPayload",
  "type": "object",
  "x-sinex-event-type": "search.analytics",
  "x-sinex-source": "search-automaton",
  "x-sinex-version": "1.0.0"
}
