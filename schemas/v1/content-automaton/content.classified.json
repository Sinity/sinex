{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Content classification",
  "properties": {
    "analysis_type": {
      "type": "string"
    },
    "categories": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "confidence": {
      "format": "double",
      "type": "number"
    },
    "content_length": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "source_event_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "analysis_type",
    "categories",
    "confidence",
    "content_length",
    "generated_at"
  ],
  "title": "ContentClassifiedPayload",
  "type": "object",
  "x-sinex-event-type": "content.classified",
  "x-sinex-source": "content-automaton",
  "x-sinex-version": "1.0.0"
}
