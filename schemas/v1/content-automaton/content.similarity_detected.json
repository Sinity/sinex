{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Content similarity detection",
  "properties": {
    "analysis_type": {
      "type": "string"
    },
    "content_fingerprint": {
      "type": "string"
    },
    "event_group_size": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "generated_at": {
      "$ref": "#/$defs/DateTime"
    },
    "similar_event_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "similarity_type": {
      "type": "string"
    }
  },
  "required": [
    "analysis_type",
    "similarity_type",
    "event_group_size",
    "content_fingerprint",
    "similar_event_ids",
    "generated_at"
  ],
  "title": "ContentSimilarityDetectedPayload",
  "type": "object",
  "x-sinex-event-type": "content.similarity_detected",
  "x-sinex-source": "content-automaton",
  "x-sinex-version": "1.0.0"
}
