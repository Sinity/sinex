{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sinex.dev/schemas/v1/service/leadership_acquired.json",
  "title": "Service Leadership Acquired Event",
  "description": "Event emitted when a service acquires leadership",
  "type": "object",
  "properties": {
    "service_name": {
      "type": "string",
      "description": "Name of the service that acquired leadership",
      "minLength": 1
    },
    "instance_id": {
      "type": "string",
      "description": "UUID of the instance that acquired leadership",
      "format": "uuid"
    },
    "hostname": {
      "type": ["string", "null"],
      "description": "Hostname of the instance"
    },
    "acquired_at": {
      "type": "string",
      "format": "date-time",
      "description": "When leadership was acquired"
    },
    "previous_leader_instance_id": {
      "type": ["string", "null"],
      "description": "UUID of the previous leader, if any",
      "format": "uuid"
    },
    "leadership_type": {
      "type": "string",
      "enum": ["initial", "takeover", "failover"],
      "description": "Type of leadership acquisition"
    },
    "version": {
      "type": ["string", "null"],
      "description": "Version of the service instance"
    },
    "metadata": {
      "type": ["object", "null"],
      "description": "Additional leadership metadata"
    }
  },
  "required": [
    "service_name",
    "instance_id",
    "acquired_at",
    "leadership_type"
  ],
  "additionalProperties": false
}