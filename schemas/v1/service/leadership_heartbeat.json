{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sinex.dev/schemas/v1/service/leadership_heartbeat.json",
  "title": "Service Leadership Heartbeat Event",
  "description": "Event emitted when a service leader sends a heartbeat",
  "type": "object", 
  "properties": {
    "service_name": {
      "type": "string",
      "description": "Name of the service",
      "minLength": 1
    },
    "instance_id": {
      "type": "string",
      "description": "UUID of the leader instance",
      "format": "uuid"
    },
    "heartbeat_time": {
      "type": "string",
      "format": "date-time", 
      "description": "When the heartbeat occurred"
    },
    "leadership_duration_seconds": {
      "type": "number",
      "description": "How long this instance has been leader",
      "minimum": 0
    },
    "health_status": {
      "type": ["string", "null"],
      "enum": [null, "healthy", "degraded", "warning"],
      "description": "Health status of the leader"
    },
    "active_connections": {
      "type": ["integer", "null"],
      "description": "Number of active connections/clients",
      "minimum": 0
    },
    "processed_items": {
      "type": ["integer", "null"],
      "description": "Number of items processed since last heartbeat",
      "minimum": 0
    }
  },
  "required": [
    "service_name",
    "instance_id",
    "heartbeat_time",
    "leadership_duration_seconds"
  ],
  "additionalProperties": false
}