{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "NATS `JetStream` stream statistics\n\nAddresses Issue 3: Stream Capacity Monitoring",
  "properties": {
    "bytes": {
      "description": "Current byte count",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "consumer_count": {
      "description": "Consumer count",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "fill_pct": {
      "description": "Fill percentage (0.0 - 100.0)",
      "format": "double",
      "type": "number"
    },
    "first_seq": {
      "description": "First sequence number",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "last_seq": {
      "description": "Last sequence number",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "max_bytes": {
      "description": "Maximum bytes",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "max_messages": {
      "description": "Maximum message count (capacity)",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "messages": {
      "description": "Current message count",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "stream": {
      "description": "Stream name",
      "type": "string"
    }
  },
  "required": [
    "stream",
    "messages",
    "max_messages",
    "bytes",
    "max_bytes",
    "consumer_count",
    "fill_pct",
    "first_seq",
    "last_seq"
  ],
  "title": "StreamStatsPayload",
  "type": "object",
  "x-sinex-event-type": "stream.stats",
  "x-sinex-source": "sinex.ingestd",
  "x-sinex-version": "1.0.0"
}
