{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Material assembly progress\n\nAddresses Issue 16: Assembly Metrics",
  "properties": {
    "active_assemblies": {
      "description": "Number of assemblies currently in progress",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "avg_duration_ms": {
      "description": "Average assembly duration (ms)",
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "buffered_slices": {
      "description": "Buffered slices waiting for completion",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "total_cancelled": {
      "description": "Total assemblies cancelled intentionally after partial capture",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_completed": {
      "description": "Total assemblies completed successfully",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_failed": {
      "description": "Total assemblies failed",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_started": {
      "description": "Total assemblies started since service start",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_timed_out": {
      "description": "Total assemblies timed out",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "active_assemblies",
    "total_started",
    "total_completed",
    "total_cancelled",
    "total_failed",
    "total_timed_out",
    "buffered_slices"
  ],
  "title": "AssemblyStatsPayload",
  "type": "object",
  "x-sinex-event-type": "assembly.stats",
  "x-sinex-source": "sinex.ingestd",
  "x-sinex-version": "1.0.0"
}
