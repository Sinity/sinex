{
  "$defs": {
    "DateTime": {
      "description": "RFC 3339 formatted date-time string",
      "format": "date-time",
      "type": "string"
    },
    "JournalSyncType": {
      "description": "Type of journal sync operation",
      "oneOf": [
        {
          "const": "initial_import",
          "description": "Initial full import",
          "type": "string"
        },
        {
          "const": "incremental",
          "description": "Incremental sync from cursor",
          "type": "string"
        },
        {
          "const": "full",
          "description": "Full re-sync",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Records the outcome of a journald cursor sync.",
  "properties": {
    "duration_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "end_cursor": {
      "type": "string"
    },
    "entries_count": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "start_cursor": {
      "type": [
        "string",
        "null"
      ]
    },
    "sync_type": {
      "$ref": "#/$defs/JournalSyncType"
    },
    "time_end": {
      "anyOf": [
        {
          "$ref": "#/$defs/DateTime"
        },
        {
          "type": "null"
        }
      ]
    },
    "time_start": {
      "anyOf": [
        {
          "$ref": "#/$defs/DateTime"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "sync_type",
    "end_cursor",
    "entries_count",
    "duration_ms"
  ],
  "title": "JournalSyncCompletedPayload",
  "type": "object",
  "x-sinex-event-type": "sync.completed",
  "x-sinex-source": "journald",
  "x-sinex-version": "1.0.0"
}
