{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "events_processed": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "git_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "memory_usage_mb": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "service_name": {
      "type": "string"
    },
    "uptime_seconds": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "service_name"
  ],
  "title": "NodeHeartbeatPayload",
  "type": "object",
  "x-sinex-event-type": "node.heartbeat",
