{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Captures a journald log entry with raw fields.",
  "properties": {
    "fields": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "message": {
      "type": "string"
    },
    "priority": {
      "format": "uint8",
      "minimum": 0.0,
      "type": "integer"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    },
    "unit": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "fields",
    "message",
    "priority",
    "timestamp"
  ],
  "title": "JournalEntryPayload",
  "type": "object"
}