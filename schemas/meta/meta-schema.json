{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sinex.local/schemas/meta/meta-schema.json",
  "title": "Sinex Event Payload Meta-Schema",
  "description": "Meta-schema for validating Sinex event payload JSON schemas",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "$id": {
      "type": "string",
      "format": "uri"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["object"]
    },
    "properties": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/property"
      },
      "minProperties": 1
    },
    "required": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "additionalProperties": {
      "type": "boolean"
    }
  },
  "required": ["$schema", "title", "type", "properties"],
  "additionalProperties": false,
  "definitions": {
    "property": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "array", "object", "null"]
        },
        "format": {
          "type": "string",
          "enum": ["date-time", "uuid", "ulid", "uri", "email", "path"]
        },
        "description": {
          "type": "string"
        },
        "enum": {
          "type": "array"
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "$ref": "#/definitions/property"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/property"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["type"],
      "additionalProperties": false
    }
  }
}