#!/usr/bin/env bash
# Pre-push drift guard for sinex.
#
# Runs scoped drift guards before allowing a push:
#   - `xtask docs schema-bundle --check` when payload/schema surfaces changed.
#   - `xtask check --changed-strict` when Rust sources changed.
#
# The changed-strict guard catches regressions in changed-file surfaces that
# compile-clean in isolation but reference APIs that have since changed on the
# target branch — the class of bug PR #1268 (and several others) shipped under
# because the author's local check ran against a stale dependency graph.
#
# The hook computes the pushed checkout's devshell paths itself before running
# `xtask`. This prevents a worktree push from inheriting the main checkout's
# target dir, database socket, or `.direnv` wrapper and falling into a surprise
# `nix develop` bootstrap before the useful guard even starts.
#
# Skip in two cases:
#   1. Pushing a branch with no commits ahead of origin/master (just
#      catching up). We have nothing to drift-check against.
#   2. The `SINEX_SKIP_DRIFT_GUARD` env var is set — emergency hatch
#      for force-pushes during recovery operations. Document each use.
#
# Install (per-repo, not committed):
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

_sinex_pre_push_xtask_env_matches_checkout() {
  [[ -n "${SINEX_DEV_ROOT:-}" ]] \
    && [[ "${SINEX_DEV_ROOT:-}" == "$REPO_ROOT" ]] \
    && command -v xtask >/dev/null 2>&1
}

_sinex_pre_push_checkout_hash() {
  printf '%s' "$REPO_ROOT" | sha256sum | cut -c1-12
}

_sinex_pre_push_cache_root() {
  local user_name checkout_hash
  user_name="${USER:-$(id -un)}"
  checkout_hash="$(_sinex_pre_push_checkout_hash)"
  printf '/var/cache/sinex/%s/%s' "$user_name" "$checkout_hash"
}

_sinex_pre_push_gateway_port() {
  local checkout_hash first_byte
  checkout_hash="$(_sinex_pre_push_checkout_hash)"
  first_byte="$((16#${checkout_hash:0:2}))"
  printf '%s' "$((19000 + first_byte))"
}

_sinex_pre_push_nats_port() {
  local checkout_hash first_byte
  checkout_hash="$(_sinex_pre_push_checkout_hash)"
  first_byte="$((16#${checkout_hash:0:2}))"
  printf '%s' "$((4222 + (first_byte % 100)))"
}

_sinex_pre_push_checkout_env() {
  local cache_root dev_state_dir target_dir pg_run_dir pg_port nats_port gateway_port
  cache_root="$(_sinex_pre_push_cache_root)"
  dev_state_dir="$cache_root/dev-state"
  target_dir="$cache_root/target"
  pg_run_dir="$dev_state_dir/run"
  pg_port="5432"
  nats_port="$(_sinex_pre_push_nats_port)"
  gateway_port="$(_sinex_pre_push_gateway_port)"

  mkdir -p "$cache_root" "$target_dir" "$dev_state_dir" "$REPO_ROOT/.sinex/state"

  env \
    CARGO_TARGET_DIR="$target_dir" \
    DATABASE_URL="postgresql:///sinex_dev?host=$pg_run_dir" \
    PGHOST="$pg_run_dir" \
    PGPORT="$pg_port" \
    PATH="$target_dir/debug:$PATH" \
    SINEX_CACHE_DIR="$cache_root" \
    SINEX_DEV_CACHE_ROOT="$cache_root" \
    SINEX_DEV_GATEWAY_PORT="$gateway_port" \
    SINEX_DEV_NATS_PORT="$nats_port" \
    SINEX_DEV_PG_PORT="$pg_port" \
    SINEX_DEV_ROOT="$REPO_ROOT" \
    SINEX_DEV_STATE_DIR="$dev_state_dir" \
    SINEX_NATS_DIR="$dev_state_dir/nats" \
    SINEX_NATS_URL="nats://127.0.0.1:$nats_port" \
    SINEX_ROOT="$REPO_ROOT" \
    SINEX_STATE_DIR="$REPO_ROOT/.sinex/state" \
    "$@"
}

_sinex_pre_push_checkout_xtask_binary() {
  local cache_root candidate
  cache_root="$(_sinex_pre_push_cache_root)"
  candidate="$cache_root/target/debug/xtask"
  _sinex_pre_push_xtask_binary_is_usable_for_branch "$candidate" && printf '%s\n' "$candidate"
}

_sinex_pre_push_checkout_xtask_wrapper() {
  local candidate
  for candidate in \
    "$REPO_ROOT/.direnv/bin/xtask" \
    "$REPO_ROOT/.direnv/flake-profile/bin/xtask"
  do
    [[ -x "$candidate" ]] && printf '%s\n' "$candidate" && return 0
  done
}

_sinex_pre_push_xtask_binary_is_current() {
  local candidate
  candidate="$1"
  [[ -x "$candidate" ]] || return 1
  ! _sinex_pre_push_xtask_sources_newer_than "$candidate"
}

_sinex_pre_push_xtask_binary_is_usable_for_branch() {
  local candidate
  candidate="$1"
  [[ -x "$candidate" ]] || return 1
  if _sinex_pre_push_branch_changes_xtask_build_inputs; then
    _sinex_pre_push_xtask_binary_is_current "$candidate"
    return $?
  fi
  return 0
}

_sinex_pre_push_xtask_sources_newer_than() {
  local candidate
  candidate="$1"
  [[ -n "$(_sinex_pre_push_newer_xtask_input "$candidate")" ]]
}

_sinex_pre_push_newer_xtask_input() {
  local candidate
  candidate="$1"
  find \
    "$REPO_ROOT/xtask/src" \
    "$REPO_ROOT/xtask/macros/src" \
    "$REPO_ROOT/xtask/build.rs" \
    "$REPO_ROOT/crate/sinex-primitives/src/events/payloads" \
    "$REPO_ROOT/Cargo.lock" \
    "$REPO_ROOT/Cargo.toml" \
    "$REPO_ROOT/xtask/Cargo.toml" \
    -type f -newer "$candidate" -print -quit 2>/dev/null
}

_sinex_pre_push_branch_changes_xtask_build_inputs() {
  local base_ref merge_base
  base_ref="${BASE_REF:-origin/master}"
  merge_base="$(git merge-base "$base_ref" HEAD 2>/dev/null)" || return 0
  [[ -n "$(_sinex_pre_push_changed_xtask_build_inputs "$merge_base")" ]]
}

_sinex_pre_push_changed_xtask_build_inputs() {
  local merge_base
  merge_base="$1"
  git diff --name-only "$merge_base" HEAD -- \
    Cargo.lock \
    Cargo.toml \
    flake.nix \
    .cargo/config.toml \
    crate/sinex-primitives/src/events/payloads \
    xtask/build.rs \
    xtask/Cargo.toml \
    xtask/src \
    xtask/macros/src
}

_sinex_pre_push_changed_schema_bundle_inputs() {
  local base_ref
  base_ref="$1"
  git diff --name-only "$base_ref" HEAD -- \
    'crate/sinex-primitives/src/events/**' \
    'crate/sinex-macros/**' \
    'crate/sinex-schema/**' \
    'schemas/v1/**'
}

_sinex_pre_push_checkout_postgres_running() {
  local cache_root pid_file pid
  cache_root="$(_sinex_pre_push_cache_root)"
  pid_file="$cache_root/dev-state/data/postgres/postmaster.pid"
  [[ -r "$pid_file" ]] || return 1
  pid="$(sed -n '1p' "$pid_file" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

_sinex_pre_push_stop_checkout_postgres() {
  local cache_root pgdata
  cache_root="$(_sinex_pre_push_cache_root)"
  pgdata="$cache_root/dev-state/data/postgres"
  [[ -d "$pgdata" ]] || return 0
  if command -v pg_ctl >/dev/null 2>&1; then
    pg_ctl -D "$pgdata" -m fast stop >/dev/null 2>&1 || true
    return 0
  fi
  _sinex_pre_push_clean_env \
    nix develop "$REPO_ROOT" --command pg_ctl -D "$pgdata" -m fast stop >/dev/null 2>&1 || true
}

_sinex_pre_push_path_xtask_binary() {
  local candidate
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    case "$candidate" in
      "$REPO_ROOT"/*|*/.direnv/*|/realm/project/sinex/.direnv/*|/realm/tmp/worktrees/*/.direnv/*)
        continue
        ;;
    esac
    [[ -x "$candidate" ]] && printf '%s\n' "$candidate" && return 0
  done < <(type -P -a xtask 2>/dev/null || true)
}

_sinex_pre_push_cached_xtask_binary() {
  local user_name cache_base candidate
  user_name="${USER:-$(id -un)}"
  cache_base="/var/cache/sinex/$user_name"
  [[ -d "$cache_base" ]] || return 0

  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    _sinex_pre_push_xtask_binary_is_usable_for_branch "$candidate" || continue
    printf '%s\n' "$candidate"
    return 0
  done < <(
    find "$cache_base" \
      -path '*/target/debug/xtask' \
      -type f \
      -executable \
      -printf '%T@ %p\n' 2>/dev/null \
      | sort -nr \
      | sed 's/^[^ ]* //'
  )
}

_sinex_pre_push_explain_xtask_rejection() {
  local label candidate newer_input
  label="$1"
  candidate="$2"
  if [[ -z "$candidate" ]]; then
    echo "[pre-push] No $label xtask candidate found." >&2
    return 0
  fi
  if [[ ! -e "$candidate" ]]; then
    echo "[pre-push] Ignoring $label xtask candidate: missing at $candidate." >&2
    return 0
  fi
  if [[ ! -x "$candidate" ]]; then
    echo "[pre-push] Ignoring $label xtask candidate: not executable at $candidate." >&2
    return 0
  fi
  if _sinex_pre_push_branch_changes_xtask_build_inputs; then
    newer_input="$(_sinex_pre_push_newer_xtask_input "$candidate")"
    if [[ -n "$newer_input" ]]; then
      echo "[pre-push] Ignoring $label xtask candidate: branch changes xtask build inputs and $newer_input is newer than $candidate." >&2
      return 0
    fi
  fi
  echo "[pre-push] Ignoring $label xtask candidate: unusable for this checkout." >&2
}

_sinex_pre_push_clean_env() {
  env \
    -u CARGO_TARGET_DIR \
    -u DATABASE_URL \
    -u PGHOST \
    -u PGPORT \
    -u SINEX_API_ADMIN_TOKEN \
    -u SINEX_API_TCP_LISTEN \
    -u SINEX_API_TLS_CERT \
    -u SINEX_API_TLS_CLIENT_CA \
    -u SINEX_API_TLS_KEY \
    -u SINEX_API_URL \
    -u SINEX_CACHE_DIR \
    -u SINEX_DEV_CACHE_ROOT \
    -u SINEX_DEV_GATEWAY_PORT \
    -u SINEX_DEV_NATS_PORT \
    -u SINEX_DEV_PG_PORT \
    -u SINEX_DEV_ROOT \
    -u SINEX_DEV_STATE_DIR \
    -u SINEX_NATS_DIR \
    -u SINEX_NATS_URL \
    -u SINEX_ROOT \
    -u SINEX_STATE_DIR \
    -u SINEX_TEST_PGDATA_DIR \
    -u SINEX_TEST_RESULTS_DIR \
    -u SINEX_TEST_TMPDIR \
    "$@"
}

_sinex_pre_push_selected_xtask() {
  local label xtask_bin xtask_dir
  label="$1"
  xtask_bin="$2"
  shift 2
  xtask_dir="$(dirname "$xtask_bin")"
  if [[ "${SINEX_PRE_PUSH_DRY_RUN:-}" == "1" ]]; then
    echo "[pre-push] Dry run: would use $label: $xtask_bin" >&2
    return 0
  fi
  echo "[pre-push] Using $label: $xtask_bin" >&2
  PATH="$xtask_dir:$PATH" _sinex_pre_push_checkout_env "$xtask_bin" "$@"
}

_sinex_pre_push_run_xtask() {
  local xtask_bin merge_base changed_inputs checkout_candidate

  merge_base="$(git merge-base "${BASE_REF:-origin/master}" HEAD 2>/dev/null || true)"
  changed_inputs=""
  if [[ -n "$merge_base" ]]; then
    changed_inputs="$(_sinex_pre_push_changed_xtask_build_inputs "$merge_base")"
  fi
  if [[ -n "$changed_inputs" ]]; then
    echo "[pre-push] Branch changes xtask build inputs; selected binary must be fresh." >&2
    printf '%s\n' "$changed_inputs" | sed 's/^/[pre-push]   input: /' >&2
  else
    echo "[pre-push] Branch does not change xtask build inputs; a built xtask binary can run this guard without rebuild." >&2
  fi

  checkout_candidate="$(_sinex_pre_push_cache_root)/target/debug/xtask"
  xtask_bin="$(_sinex_pre_push_checkout_xtask_binary || true)"
  if [[ -n "$xtask_bin" ]]; then
    _sinex_pre_push_selected_xtask "checkout-local xtask binary" "$xtask_bin" "$@"
    return $?
  fi
  _sinex_pre_push_explain_xtask_rejection "checkout-local" "$checkout_candidate"

  if _sinex_pre_push_xtask_env_matches_checkout; then
    xtask_bin="$(command -v xtask)"
    case "$xtask_bin" in
      */.direnv/*)
        echo "[pre-push] Ignoring active devshell xtask wrapper: .direnv wrapper would rebuild before guard selection." >&2
        ;;
      *)
        if _sinex_pre_push_xtask_binary_is_usable_for_branch "$xtask_bin"; then
          _sinex_pre_push_selected_xtask "active devshell xtask" "$xtask_bin" "$@"
          return $?
        fi
        _sinex_pre_push_explain_xtask_rejection "active devshell" "$xtask_bin"
        ;;
    esac
  fi

  xtask_bin="$(_sinex_pre_push_path_xtask_binary || true)"
  if [[ -n "$xtask_bin" ]]; then
    if _sinex_pre_push_xtask_binary_is_usable_for_branch "$xtask_bin"; then
      _sinex_pre_push_selected_xtask "read-only PATH xtask fallback" "$xtask_bin" "$@"
      return $?
    fi
    _sinex_pre_push_explain_xtask_rejection "PATH fallback" "$xtask_bin"
  fi

  xtask_bin="$(_sinex_pre_push_cached_xtask_binary || true)"
  if [[ -n "$xtask_bin" ]]; then
    _sinex_pre_push_selected_xtask "read-only cached xtask fallback" "$xtask_bin" "$@"
    return $?
  fi

  xtask_bin="$(_sinex_pre_push_checkout_xtask_wrapper || true)"
  if [[ -n "$xtask_bin" ]]; then
    if [[ "${SINEX_PRE_PUSH_DRY_RUN:-}" == "1" ]]; then
      echo "[pre-push] Dry run: would rebuild through checkout xtask wrapper: $xtask_bin" >&2
      return 0
    fi
    echo "[pre-push] Rebuilding through checkout xtask wrapper: $xtask_bin" >&2
    xtask_dir="$(dirname "$xtask_bin")"
    PATH="$xtask_dir:$PATH" _sinex_pre_push_checkout_env "$xtask_bin" "$@"
    return $?
  fi

  if [[ "${SINEX_PRE_PUSH_DRY_RUN:-}" == "1" ]]; then
    echo "[pre-push] Dry run: would rebuild through nix develop because no usable checkout wrapper or binary was found." >&2
    return 0
  fi
  echo "[pre-push] No usable checkout wrapper or binary found; rebuilding through nix develop." >&2
  _sinex_pre_push_clean_env \
    nix develop "$REPO_ROOT" --command xtask "$@"
}

_sinex_pre_push_record_drift_bypass() {
  local branch="$1"
  local sha="$2"

  local xtask_bin
  local xtask_dir

  xtask_bin="$(_sinex_pre_push_checkout_xtask_binary || true)"
  if [[ -n "$xtask_bin" ]]; then
    xtask_dir="$(dirname "$xtask_bin")"
    PATH="$xtask_dir:$PATH" _sinex_pre_push_checkout_env "$xtask_bin" record-drift-bypass --branch "$branch" --sha "$sha" 2>/dev/null || true
    return 0
  fi

  xtask_bin="$(_sinex_pre_push_path_xtask_binary || true)"
  if [[ -n "$xtask_bin" ]]; then
    xtask_dir="$(dirname "$xtask_bin")"
    PATH="$xtask_dir:$PATH" _sinex_pre_push_checkout_env "$xtask_bin" record-drift-bypass --branch "$branch" --sha "$sha" 2>/dev/null || true
    return 0
  fi

  xtask_bin="$(_sinex_pre_push_cached_xtask_binary || true)"
  if [[ -n "$xtask_bin" ]]; then
    xtask_dir="$(dirname "$xtask_bin")"
    PATH="$xtask_dir:$PATH" _sinex_pre_push_checkout_env "$xtask_bin" record-drift-bypass --branch "$branch" --sha "$sha" 2>/dev/null || true
    return 0
  fi

  # Keep the emergency bypass non-blocking. A foreign/stale shell must not
  # rebuild xtask or enter nix just to record the audit event.
  echo "[pre-push] Drift-bypass audit recording skipped: no usable xtask binary outside Nix." >&2
}

if [[ "${SINEX_SKIP_DRIFT_GUARD:-}" == "1" ]]; then
  echo "[pre-push] SINEX_SKIP_DRIFT_GUARD=1 — drift guard bypassed." >&2
  # Record the bypass in xtask history (#1565)
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  sha="$(git rev-parse HEAD 2>/dev/null || echo "")"
  _sinex_pre_push_record_drift_bypass "$branch" "$sha"
  exit 0
fi

# Determine the upstream / base to diff against. Default to origin/master
# when the local branch tracks something else (feature branches).
BASE_REF="${BASE_REF:-origin/master}"
if ! git rev-parse --verify "$BASE_REF" >/dev/null 2>&1; then
  echo "[pre-push] $BASE_REF not found locally; skipping drift guard." >&2
  exit 0
fi

if [[ "${SINEX_PRE_PUSH_DRY_RUN:-}" == "1" ]]; then
  echo "[pre-push] Dry run: probing xtask selection without running drift guards." >&2
  _sinex_pre_push_run_xtask docs schema-bundle --check >&2
  exit 0
fi

# If HEAD == BASE_REF, nothing to check.
if [[ "$(git rev-parse HEAD)" == "$(git rev-parse "$BASE_REF")" ]]; then
  echo "[pre-push] HEAD == $BASE_REF; skipping drift guard." >&2
  exit 0
fi

changed_schema_bundle_inputs="$(_sinex_pre_push_changed_schema_bundle_inputs "$BASE_REF" 2>/dev/null || true)"
changed_rust_inputs="$(git diff --name-only "$BASE_REF" HEAD -- '*.rs' 2>/dev/null || true)"

if [[ -z "$changed_schema_bundle_inputs" && -z "$changed_rust_inputs" ]]; then
  echo "[pre-push] No schema-bundle or .rs changes vs $BASE_REF; skipping drift guard." >&2
  exit 0
fi

if [[ -n "$changed_schema_bundle_inputs" ]]; then
  echo "[pre-push] Running xtask docs schema-bundle --check ..." >&2
  printf '%s\n' "$changed_schema_bundle_inputs" | sed 's/^/[pre-push]   schema input: /' >&2
  schema_bundle_status=0
  _sinex_pre_push_run_xtask docs schema-bundle --check >&2 || schema_bundle_status=$?
  if [[ "$schema_bundle_status" != "0" ]]; then
    echo "" >&2
    echo "[pre-push] SCHEMA BUNDLE DRIFT GUARD FAILED." >&2
    echo "Your payload/schema changes left schemas/v1 stale." >&2
    echo "Run \`xtask docs schema-bundle\`, commit the generated bundle, and push again." >&2
    exit 1
  fi
  echo "[pre-push] Schema bundle drift guard passed." >&2
fi

if [[ -n "$changed_rust_inputs" ]]; then
  echo "[pre-push] Running xtask check --changed-strict $BASE_REF ..." >&2
  pre_push_owned_postgres=0
  if ! _sinex_pre_push_checkout_postgres_running; then
    pre_push_owned_postgres=1
  fi

  pre_push_status=0
  _sinex_pre_push_run_xtask check --changed-strict "$BASE_REF" >&2 || pre_push_status=$?

  if [[ "$pre_push_owned_postgres" == "1" ]]; then
    _sinex_pre_push_stop_checkout_postgres
  fi

  if [[ "$pre_push_status" != "0" ]]; then
    echo "" >&2
    echo "[pre-push] DRIFT GUARD FAILED." >&2
    echo "Your changes introduce diagnostics on affected packages that didn't exist on $BASE_REF." >&2
    echo "Fix them, or bypass with SINEX_SKIP_DRIFT_GUARD=1 and explain in the PR body why." >&2
    exit 1
  fi
  echo "[pre-push] Drift guard passed." >&2
fi

echo "[pre-push] Pre-push drift guards passed." >&2
