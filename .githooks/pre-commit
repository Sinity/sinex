#!/usr/bin/env bash
# Pre-commit hook for schema validation
# Install with: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# 1. Check code formatting (only for staged Rust files)
echo "🎨 Checking code formatting..."

# Get list of staged Rust files
STAGED_RUST_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '\.rs$' || true)

if [ -n "$STAGED_RUST_FILES" ]; then
    # Check if staged files are formatted
    FORMATTING_ISSUES=""
    
    for file in $STAGED_RUST_FILES; do
        if [ -f "$file" ]; then
            # Check formatting for individual file (only .rs files)
            if [[ "$file" == *.rs ]]; then
                if [ -z "$IN_NIX_SHELL" ]; then
                    # Not in nix shell, use nix develop wrapper
                    if ! nix develop --command rustfmt --check "$file" >/dev/null 2>&1; then
                        FORMATTING_ISSUES="${FORMATTING_ISSUES}${file}\n"
                    fi
                else
                    # In nix shell, run directly
                    if ! rustfmt --check "$file" >/dev/null 2>&1; then
                        FORMATTING_ISSUES="${FORMATTING_ISSUES}${file}\n"
                    fi
                fi
            fi
        fi
    done
    
    if [ -n "$FORMATTING_ISSUES" ]; then
        echo -e "${RED}✗ Code is not formatted in staged files:${NC}"
        echo -e "$FORMATTING_ISSUES"
        echo "Run 'just fmt' to fix formatting issues."
        exit 1
    fi
    echo -e "${GREEN}✓ Code formatting check passed for staged files${NC}"
else
    echo "No Rust files staged, skipping formatting check"
fi

# 2. Check if schemas were modified
if git diff --cached --name-only | grep -q "^schemas/"; then
    echo "Schema files modified, running validation..."
    
    # Run schema compatibility check
    if ./scripts/schema-compatibility-check.sh; then
        echo -e "${GREEN}✓ Schema validation passed${NC}"
    else
        echo -e "${RED}✗ Schema validation failed${NC}"
        echo "Commit aborted. Please fix schema issues and try again."
        exit 1
    fi
else
    echo "No schema files modified, skipping validation"
fi

echo -e "${GREEN}Pre-commit checks completed successfully${NC}"