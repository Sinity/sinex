  "query": "\n            SELECT \n                j.id as \"job_id: Ulid\",\n                j.sensor_type,\n                j.status,\n                j.updated_at,\n                s.last_successful_acquisition,\n                s.error_count\n            FROM raw.sensor_jobs j\n            LEFT JOIN raw.sensor_states s ON j.id = s.job_id\n            WHERE j.id = $1::ulid\n            ",
