  "query": "\n            SELECT \n                id::text as id,\n                source,\n                event_type,\n                schema_version,\n                schema_content,\n                content_hash,\n                is_active,\n                updated_at\n            FROM sinex_schemas.event_payload_schemas\n            WHERE source = $1 \n                AND ($2 OR is_active = true)\n            ORDER BY event_type, updated_at DESC\n            ",
