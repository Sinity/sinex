{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                source,\n                COUNT(*) as event_count,\n                MIN(ts_orig) as first_event,\n                MAX(ts_orig) as last_event\n            FROM core.events\n            WHERE ts_orig >= $1\n            GROUP BY source\n            ORDER BY event_count DESC\n            LIMIT $2\n            ",
