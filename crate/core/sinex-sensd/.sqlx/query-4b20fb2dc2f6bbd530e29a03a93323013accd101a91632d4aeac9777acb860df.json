  "query": "\n            SELECT \n                id::uuid as \"id!: Id<Operation>\",\n                operation_type,\n                operator,\n                scope,\n                result_status,\n                result_message,\n                preview_summary,\n                duration_ms\n            FROM core.operations_log \n            WHERE operator = $1\n            ORDER BY id DESC\n            LIMIT $2\n            ",
