  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id::uuid as \"id!: crate::Ulid\",\n                material_kind,\n                source_identifier,\n                status,\n                timing_info_type,\n                metadata,\n                staged_at,\n                start_time,\n                end_time,\n                staged_by,\n                staged_on_host,\n                optional_blob_id::uuid as \"optional_blob_id?: crate::Ulid\"\n            FROM raw.source_material_registry\n            WHERE (metadata->>'archived') IS DISTINCT FROM 'true'\n              AND staged_at < $1\n            ORDER BY staged_at ASC\n            LIMIT $2\n            ",
