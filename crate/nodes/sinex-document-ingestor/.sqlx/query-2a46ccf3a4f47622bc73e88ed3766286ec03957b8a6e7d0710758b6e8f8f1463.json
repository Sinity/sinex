  "query": "\n            SELECT \n                id as \"id: Ulid\",\n                sensor_type,\n                target_uri,\n                config,\n                status,\n                priority,\n                updated_at\n            FROM raw.sensor_jobs\n            WHERE status = 'active'\n            ORDER BY priority DESC, updated_at\n            LIMIT $1\n            ",
