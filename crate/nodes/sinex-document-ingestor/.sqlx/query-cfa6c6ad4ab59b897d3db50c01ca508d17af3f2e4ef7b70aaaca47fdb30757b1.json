{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                sm.id as \"material_id: Ulid\",\n                sm.source_identifier,\n                sm.material_kind,\n                sm.staged_at,\n                sm.status as lifecycle_status,\n                sm.metadata,\n                sm.optional_blob_id as \"blob_id: Ulid\",\n                b.size_bytes,\n                b.mime_type\n            FROM raw.source_material_registry sm\n            LEFT JOIN core.blobs b ON sm.optional_blob_id = b.id\n            WHERE sm.id = $1::ulid\n            ",
