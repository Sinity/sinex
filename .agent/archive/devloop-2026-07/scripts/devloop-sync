#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

root=".agent/conductor-devloop"
mkdir -p "$root"
mkdir -p "$root/context"

tmp_files=()
cleanup_tmp_files() {
  local tmp_file
  for tmp_file in "${tmp_files[@]}"; do
    [[ -e "$tmp_file" ]] && rm -f "$tmp_file"
  done
}
trap cleanup_tmp_files EXIT

make_tmp() {
  local dir="$1"
  local name="$2"
  local tmp
  tmp="$(mktemp "$dir/.${name}.XXXXXX.tmp")"
  tmp_files+=("$tmp")
  printf '%s\n' "$tmp"
}

if [[ -x .agent/scripts/devloop-refresh-demos ]]; then
  .agent/scripts/devloop-refresh-demos .agent/demos/sinex >/dev/null
  printf 'refreshed demos\n'
fi

if [[ -x .agent/scripts/devloop-refresh-events ]]; then
  .agent/scripts/devloop-refresh-events >/dev/null
  printf 'refreshed events\n'
fi

context_index="$root/context/INDEX.md"
context_index_tmp="$(make_tmp "$root/context" "INDEX.md")"
{
  printf '# Conductor Context Index\n\n'
  printf 'Generated: %s\n\n' "$(date --iso-8601=seconds)"
  printf 'This file is generated by `.agent/scripts/devloop-sync`. It keeps supporting context notes discoverable without turning the conductor root into a loose dump.\n\n'
  printf '## Files\n\n'
  if find "$root/context" -type f ! -name 'INDEX.md' -print -quit | rg -q .; then
    find "$root/context" -type f ! -name 'INDEX.md' -printf '%P\t%s\t%TY-%Tm-%TdT%TH:%TM:%TS%Tz\n' \
      | sort \
      | while IFS=$'\t' read -r file size mtime; do
        role="context"
        case "$file" in
          handoffs/*) role="handoff" ;;
          *.json|*.jsonl|*.csv|*.log|*.out|*.txt) role="raw/evidence" ;;
        esac
        printf -- '- `%s` (%s bytes, %s, %s)\n' "$file" "$size" "$role" "$mtime"
      done
  else
    printf 'No supporting context notes yet.\n'
  fi
} >"$context_index_tmp"
mv -f "$context_index_tmp" "$context_index"
printf 'wrote %s\n' "$context_index"

manifest="$root/MANIFEST.md"
manifest_tmp="$(make_tmp "$root" "MANIFEST.md")"
{
  printf '# Conductor Packet Manifest\n\n'
  printf 'Generated: %s\n\n' "$(date --iso-8601=seconds)"
  printf '## Active Root\n\n'
  printf '`%s` is the canonical active loop root. It is not a mirror of scratch or handoff.\n\n' "$root"
  if [[ -f .agent/devloop-contract.json ]] && command -v jq >/dev/null 2>&1; then
    printf 'Shared contract: `.agent/devloop-contract.json` version `%s` with `%s` primitive names.\n\n' \
      "$(jq -r '.version // "unknown"' .agent/devloop-contract.json)" \
      "$(jq -r '.script_primitives | length' .agent/devloop-contract.json)"
  fi
  printf 'Generated sidecars: `EVENTS.jsonl` is the log event stream; `PHASES.jsonl` is the timing/focus subset for velocity analysis.\n\n'
  printf '## Files\n\n'
  find "$root" -maxdepth 1 -type f -printf '%f\t%s\n' | sort | while IFS=$'\t' read -r file size; do
    printf -- '- `%s` (%s bytes)\n' "$file" "$size"
  done
  printf '\n## Context\n\n'
  if [[ -f "$context_index" ]]; then
    context_count="$(find "$root/context" -type f ! -name 'INDEX.md' | wc -l | tr -d ' ')"
    printf -- '- `%s` indexes %s supporting context file(s).\n' "$context_index" "$context_count"
  fi
  printf '\n## Script Hashes\n\n'
  find .agent/scripts -maxdepth 1 -type f -name 'devloop-*' -print0 \
    | sort -z \
    | while IFS= read -r -d '' script; do
      hash="$(sha256sum "$script" | awk '{print $1}')"
      printf -- '- `%s` `%s`\n' "$(basename "$script")" "$hash"
    done
  printf '\n## Primitive Contract\n\n'
  if [[ -f .agent/devloop-contract.json ]] && command -v jq >/dev/null 2>&1; then
    mapfile -t required_primitives < <(jq -r '.script_primitives[]' .agent/devloop-contract.json)
    mapfile -t retired_primitives < <(jq -r '.retired_script_primitives[]' .agent/devloop-contract.json)
    printf 'Required primitives from `.agent/devloop-contract.json`:\n\n'
    for primitive in "${required_primitives[@]}"; do
      path=".agent/scripts/$primitive"
      if [[ -x "$path" ]]; then
        status="ok"
      elif [[ -f "$path" ]]; then
        status="not executable"
      else
        status="missing"
      fi
      printf -- '- `%s` - %s\n' "$primitive" "$status"
    done

    printf '\nExtra devloop primitive names:\n\n'
    extra_primitives="$(
      comm -23 \
        <(find .agent/scripts -maxdepth 1 -type f -name 'devloop-*' -printf '%f\n' | sort) \
        <(printf '%s\n' "${required_primitives[@]}" | sort) \
        || true
    )"
    if [[ -n "$extra_primitives" ]]; then
      printf '%s\n' "$extra_primitives" | while IFS= read -r primitive; do
        printf -- '- `%s`\n' "$primitive"
      done
    else
      printf -- '- none\n'
    fi

    printf '\nRetired primitive files:\n\n'
    retired_found=false
    for primitive in "${retired_primitives[@]}"; do
      if [[ -e ".agent/scripts/$primitive" ]]; then
        retired_found=true
        printf -- '- `%s`\n' "$primitive"
      fi
    done
    if [[ "$retired_found" == false ]]; then
      printf -- '- none\n'
    fi

    printf '\nFocus modes: `%s`\n' "$(jq -r '.focus_modes | join("`, `")' .agent/devloop-contract.json)"
  else
    printf 'Skipped: `.agent/devloop-contract.json` or `jq` unavailable.\n'
  fi
} >"$manifest_tmp"
mv -f "$manifest_tmp" "$manifest"
printf 'wrote %s\n' "$manifest"
