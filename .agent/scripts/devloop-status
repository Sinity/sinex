#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

current_dir=".agent/conductor-devloop"
log="$current_dir/OPERATING-LOG.md"
active_loop="$current_dir/ACTIVE-LOOP.md"
queue="$current_dir/QUEUE.md"
contract=".agent/devloop-contract.json"
mode="full"
last_log_entry_limit="${DEVLOOP_STATUS_LAST_LOG_LINES:-48}"

usage() {
  cat <<'EOF'
Usage: .agent/scripts/devloop-status [--quick|--focus]

Modes:
  --focus    Print current focus, next action, and queue, then exit.
  --quick    Print git/current-state/pressure without slower xtask/source scans.
  --help     Show this help.
EOF
}

for arg in "$@"; do
  case "$arg" in
    --quick)
      mode="quick"
      ;;
    --focus|--focus-only)
      mode="focus"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$arg" >&2
      usage >&2
      exit 2
      ;;
  esac
done

# shellcheck source=.agent/scripts/lib/proof-processes.sh
source ".agent/scripts/lib/proof-processes.sh"

print_section() {
  local heading="$1"
  local limit="${2:-12}"
  if [[ ! -f "$active_loop" ]]; then
    return
  fi
  awk -v heading="$heading" '
    $0 == heading {in_section=1; next}
    in_section && /^## / {exit}
    in_section {print}
  ' "$active_loop" | sed '/^[[:space:]]*$/d' | sed -n "1,${limit}p"
}

latest_focus_timestamp() {
  local path="$1"
  awk '/^## Focus Change / {print $4}' "$path" | sort | tail -n 1
}

print_queue_summary() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "missing $path"
    return
  fi

  if rg -q '^No queued directives\.' "$path"; then
    echo "No live queued directives."
  else
    awk '
      /^## Completed / {exit}
      /^## / {
        if (seen >= 3) exit
        seen++
        print
        next
      }
      seen > 0 && seen <= 3 {print}
    ' "$path" | sed '/^[[:space:]]*$/d' | sed -n '1,36p'
  fi

  latest_completed="$(
    awk '/^## Completed / {header=$0} END {print header}' "$path"
  )"
  if [[ -n "$latest_completed" ]]; then
    printf 'latest completed: %s\n' "$latest_completed"
  fi
}

print_beads_summary() {
  echo "== beads (task substrate) =="
  if ! command -v bd >/dev/null 2>&1 || ! bd where >/dev/null 2>&1; then
    echo "bd unavailable; task substrate not readable from this shell"
    return
  fi
  local in_progress
  in_progress="$(bd list --status=in_progress 2>/dev/null | grep -v '^No issues found' | sed '/^[[:space:]]*$/d' | sed -n '1,8p')"
  if [[ -n "$in_progress" ]]; then
    printf -- '-- in progress (claimed) --\n%s\n' "$in_progress"
  else
    echo "no claimed issues; pick from bd ready"
  fi
  printf -- '-- ready (top) --\n'
  bd ready 2>/dev/null | sed '/^[[:space:]]*$/d' | sed -n '1,12p'
  printf -- '-- blocked --\n'
  bd blocked 2>/dev/null | sed -n '2,3p' | sed '/^[[:space:]]*$/d'
}

print_active_loop_summary() {
  echo "== active loop summary =="
  if [[ -f "$active_loop" ]]; then
    printf -- '-- current slice --\n'
    print_section "## Current Slice" 12
    printf -- '-- current focus --\n'
    print_section "## Current Focus" 8
    printf -- '-- next action --\n'
    print_section "## Next Action" 10
  else
    echo "missing $active_loop"
  fi

  echo
  echo "== queued directives =="
  print_queue_summary "$queue"

  echo
  print_beads_summary
}

print_active_state_freshness() {
  echo "== active-state freshness =="
  if [[ -f "$log" && -f "$active_loop" ]]; then
    last_log_header="$(
      awk '/^## [0-9]{4}-[0-9]{2}-[0-9]{2}T/ {h=$0} END {print h}' "$log"
    )"
    last_log_ts="$(sed -E 's/^## ([^ ]+) .*/\1/' <<<"$last_log_header")"
    last_log_phase="$(sed -E 's/^## [^ ]+ — (.*)$/\1/' <<<"$last_log_header")"
    last_focus_ts="$(latest_focus_timestamp "$active_loop")"
    printf 'last operating-log: %s (%s)\n' "${last_log_ts:-unknown}" "${last_log_phase:-unknown}"
    printf 'last focus change:  %s\n' "${last_focus_ts:-none}"
    if [[ "$last_log_phase" =~ ^(Proof|Artifact)(:|$) && -n "${last_focus_ts:-}" && -n "${last_log_ts:-}" && "$last_focus_ts" < "$last_log_ts" ]]; then
      echo "note: latest proof/artifact log is newer than the last focus change; confirm ACTIVE-LOOP.md still reflects the current slice."
    fi
  else
    echo "missing log or active loop"
  fi
}

psi_value() {
  local file="$1"
  local section="$2"
  local key="$3"
  awk -v section="$section" -v key="$key" '
    $1 == section {
      for (i = 2; i <= NF; i++) {
        split($i, pair, "=")
        if (pair[1] == key) {
          print pair[2]
          exit
        }
      }
    }
  ' "$file"
}

pressure_level() {
  local some_avg10="$1"
  local full_avg10="$2"
  awk -v some="$some_avg10" -v full="$full_avg10" '
    BEGIN {
      if (full >= 20 || some >= 30) {
        print "high"
      } else if (full >= 5 || some >= 10) {
        print "elevated"
      } else {
        print "nominal"
      }
    }
  '
}

echo "== time =="
date --iso-8601=seconds
printf 'mode: %s\n' "$mode"

if [[ "$mode" == "focus" ]]; then
  echo
  print_active_loop_summary
  echo
  print_active_state_freshness
  exit 0
fi

echo
echo "== devloop root =="
printf 'cold start: .agent/DEVLOOP.md\n'
printf 'active root: %s\n' "$current_dir"
printf 'source of truth: conductor-devloop state; scratch is supporting research only\n'
if [[ -f "$contract" ]] && command -v jq >/dev/null 2>&1; then
  printf 'shared contract: %s (v%s, %s primitives)\n' \
    "$contract" \
    "$(jq -r '.version // "unknown"' "$contract")" \
    "$(jq -r '.script_primitives | length' "$contract")"
  printf 'focus modes: %s\n' "$(jq -r '.focus_modes | join(", ")' "$contract")"
  printf 'generated packet files: %s\n' "$(jq -r '.generated_packet_files | join(", ")' "$contract")"
  printf 'forbidden steady-state paths: %s\n' "$(jq -r '.forbidden_steady_state_paths | join(", ")' "$contract")"
else
  printf 'shared contract: %s (missing or jq unavailable)\n' "$contract"
fi

echo
echo "== packet size =="
if [[ -d "$current_dir" ]]; then
  du -sh "$current_dir" 2>/dev/null || true
  find "$current_dir" -maxdepth 2 -type f -printf '%p\t%s\n' \
    | sort -k2nr \
    | sed -n '1,8p'
else
  echo "missing $current_dir"
fi
if command -v jq >/dev/null 2>&1; then
  echo "-- generated sidecars --"
  for sidecar in "$current_dir/EVENTS.jsonl" "$current_dir/PHASES.jsonl"; do
    if [[ -f "$sidecar" ]]; then
      records="$(jq -sr 'length' "$sidecar" 2>/dev/null || printf '?')"
      full_body_records="$(jq -sr '[.[] | select(has("body"))] | length' "$sidecar" 2>/dev/null || printf '?')"
      printf '%s: %s bytes, %s records, legacy_full_body_records=%s\n' \
        "$sidecar" "$(wc -c <"$sidecar" | tr -d ' ')" "$records" "$full_body_records"
    fi
  done
fi

echo
echo "== git =="
git status --short
agent_escapees="$(
  git ls-files --others --exclude-standard .agent 2>/dev/null \
    | sed -n '1,20p' \
    || true
)"
if [[ -n "$agent_escapees" ]]; then
  echo "-- untracked .agent files escaping ignore policy --"
  printf '%s\n' "$agent_escapees"
fi

echo
print_active_loop_summary

echo
echo "== last operating-log entry =="
if [[ -f "$log" ]]; then
  awk -v limit="$last_log_entry_limit" -v log_path="$log" '
    /^## [0-9]{4}-[0-9]{2}-[0-9]{2}T/ {start=NR}
    {lines[NR]=$0}
    END {
      if (!start) exit
      total = NR - start + 1
      max = limit + 0
      if (max <= 0 || total <= max) {
        for (i=start; i<=NR; i++) print lines[i]
        exit
      }
      for (i=start; i<start+max; i++) print lines[i]
      printf "... truncated %d additional line(s); read %s for the full entry.\n", total - max, log_path
    }
  ' "$log"
else
  echo "missing $log"
fi

echo
print_active_state_freshness

if [[ "$mode" != "quick" ]]; then
  echo
  echo "== active xtask jobs =="
  if command -v xtask >/dev/null 2>&1; then
    xtask jobs active 2>/dev/null || true
  else
    echo "xtask not on PATH"
  fi

  echo
  echo "== foreground proof lanes =="
  print_proof_process_summary status

  echo
  echo "== recent proof overlap =="
  if command -v xtask >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    overlap_json="$(xtask history overlap latest --command test --limit 5 2>/dev/null || true)"
    if [[ -z "$overlap_json" ]]; then
      echo "no recent xtask test overlap data"
    elif ! jq -e '.data.target.id' >/dev/null 2>&1 <<<"$overlap_json"; then
      echo "no recent xtask test invocation to inspect"
    else
      target_id="$(jq -r '.data.target.id' <<<"$overlap_json")"
      mapfile -t overlaps < <(
        jq -r '
          .data.overlapping_invocations[]?
          | select((.overlap_secs // 0) >= 5)
          | select((.command | tostring) | test("^(test|check|build|docs|schema|impact)$|^infra smoke$"))
          | "overlap id=\(.id) command=\(.command) status=\(.status) overlap_secs=\(.overlap_secs | floor)"
        ' <<<"$overlap_json"
      )
      if [[ "${#overlaps[@]}" -gt 0 ]]; then
        printf 'latest xtask test #%s overlapped other xtask work; serialize focused package tests unless explicitly isolated\n' "$target_id"
        printf '%s\n' "${overlaps[@]}" | sed -n '1,8p'
      else
        printf 'latest xtask test #%s has no material xtask invocation overlap\n' "$target_id"
      fi
    fi
  else
    echo "cannot inspect recent xtask test overlap without xtask and jq"
  fi

  echo
  echo "== dev source bindings =="
  if [[ -x .agent/scripts/lib/dev-source-bindings.sh ]]; then
    .agent/scripts/lib/dev-source-bindings.sh status || true
  else
    echo "missing .agent/scripts/lib/dev-source-bindings.sh"
  fi
fi

echo
echo "== memory =="
free -h

echo
echo "== pressure =="
mem_some_avg10="$(psi_value /proc/pressure/memory some avg10)"
mem_full_avg10="$(psi_value /proc/pressure/memory full avg10)"
io_some_avg10="$(psi_value /proc/pressure/io some avg10)"
io_full_avg10="$(psi_value /proc/pressure/io full avg10)"
printf 'memory: level=%s some.avg10=%s full.avg10=%s | ' \
  "$(pressure_level "$mem_some_avg10" "$mem_full_avg10")" \
  "$mem_some_avg10" \
  "$mem_full_avg10"
tr '\n' ' ' </proc/pressure/memory
printf '\n'
printf 'io:     level=%s some.avg10=%s full.avg10=%s | ' \
  "$(pressure_level "$io_some_avg10" "$io_full_avg10")" \
  "$io_some_avg10" \
  "$io_full_avg10"
tr '\n' ' ' </proc/pressure/io
printf '\n'

echo
echo "== blocked tasks =="
blocked_tasks="$(
  ps -eo stat,pid,ppid,etime,rss,comm,args --no-headers \
    | awk '$1 ~ /^D/ {print}' \
    | sed -n '1,12p'
)"
if [[ -n "$blocked_tasks" ]]; then
  printf '%-6s %-8s %-8s %-10s %-9s %-16s %s\n' \
    "STAT" "PID" "PPID" "ELAPSED" "RSS_KB" "COMMAND" "ARGS"
  printf '%s\n' "$blocked_tasks" \
    | awk '{
        stat=$1; pid=$2; ppid=$3; etime=$4; rss=$5; comm=$6;
        sub(/^[^ ]+[ ]+[^ ]+[ ]+[^ ]+[ ]+[^ ]+[ ]+[^ ]+[ ]+[^ ]+[ ]+/, "");
        printf "%-6s %-8s %-8s %-10s %-9s %-16s %s\n", stat, pid, ppid, etime, rss, comm, $0
      }'
else
  echo "no D-state tasks"
fi

if [[ "$mode" != "quick" ]]; then
  echo
  echo "== likely loop-affecting processes =="
  ps -eo pid,ppid,stat,etime,rss,comm,args --sort=-rss \
    | rg 'codex|claude|serena|codebase-memory|polylogued|sinexd|postgres|nats|xtask|cargo|rustc|nextest|chrome|kitty' \
    | sed -n '1,30p' || true
fi
