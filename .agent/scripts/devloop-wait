#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "$#" -lt 4 ]]; then
  cat <<'EOF'
Usage: .agent/scripts/devloop-wait <job-or-command> <proof-claim> <poll-in> <mode-task>

Record an active wait state with an explicit poll time and mode-rotation task.
Use this immediately after starting a long build/test/docs/runtime command.
EOF
  exit 0
fi

waiting_on="$1"
proof_claim="$2"
poll_in="$3"
mode_task="$4"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

log_path=".agent/conductor-devloop/OPERATING-LOG.md"
timestamp="$(date --iso-8601=seconds)"
mkdir -p "$(dirname "$log_path")"

# shellcheck source=.agent/scripts/lib/proof-processes.sh
source ".agent/scripts/lib/proof-processes.sh"
proof_snapshot="$(print_proof_process_summary status)"
proof_resource_advice="$(print_serialized_proof_advice "$waiting_on")"

cat >>"$log_path" <<EOF

## $timestamp — wait state: $waiting_on

Loop phase: verify | velocity
Focus: Proof -> Velocity
Waiting on: $waiting_on
Proof claim: $proof_claim
$proof_resource_advice
Next poll: $poll_in
Mode rotation: $mode_task
Escalation trigger: if the command exceeds the expected poll window without a
new signal, inspect job status/output and host pressure before starting any
duplicate heavy work.
Foreground proof lanes at wait recording:
$proof_snapshot
Velocity note: waiting is active loop time; rotate focus deliberately, do the
mode task, then poll.
EOF

.agent/scripts/devloop-sync >/dev/null
printf '%s\n' "$log_path"
