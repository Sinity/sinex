#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "$#" -lt 6 ]]; then
  cat <<'EOF'
Usage: .agent/scripts/devloop-demo <trigger> <candidates> <selected> <artifact-action> <proof-caveat> <next-question>

Record the live demo radar: new/improved artifact candidates, the selected
artifact move, and the proof/caveat that keeps it honest.

Use at loop start, after surprising evidence, after proof, and before handoff.
EOF
  exit 0
fi

trigger="$1"
candidates="$2"
selected="$3"
artifact_action="$4"
proof_caveat="$5"
next_question="$6"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

current=".agent/conductor-devloop"
radar="$current/DEMO-RADAR.md"
log="$current/OPERATING-LOG.md"
timestamp="$(date --iso-8601=seconds)"
mkdir -p "$current"

if [[ ! -f "$radar" ]]; then
  cat >"$radar" <<'EOF'
# Demo Radar

This file is the recurring demo-generation checkpoint for the Sinex conductor
loop. It should stay current enough that the next agent can see what artifact
should exist next, what was selected, and what proof/caveat makes the artifact
honest.
EOF
fi

cat >>"$radar" <<EOF

## $timestamp

Trigger: $trigger
Candidate demos: $candidates
Selected/improved demo: $selected
Artifact action: $artifact_action
Proof/caveat: $proof_caveat
Next demo question: $next_question
EOF

cat >>"$log" <<EOF

## $timestamp — demo radar

Loop phase: choose | artifact | reflect
Focus: Direction -> Artifact
Trigger: $trigger
Candidate demos: $candidates
Selected/improved demo: $selected
Artifact action: $artifact_action
Proof/caveat: $proof_caveat
Velocity note: demo brainstorming is now an explicit checkpoint, not an implicit memory burden.
Next decision: $next_question
EOF

python3 - "$current/ACTIVE-LOOP.md" "$timestamp" "$trigger" "$selected" "$artifact_action" "$proof_caveat" "$next_question" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
timestamp, trigger, selected, artifact_action, proof_caveat, next_question = sys.argv[2:8]

focus_replacement = (
    "## Current Focus\n\n"
    "Focus: Direction -> Artifact\n\n"
    f"Trigger: {trigger}\n\n"
    f"Decision: {next_question}\n"
)
next_action_replacement = (
    "## Next Action\n\n"
    f"1. {next_question}\n"
)

def replace_section(text: str, heading: str, replacement: str) -> str:
    start = text.find(heading)
    if start == -1:
        if text and not text.endswith("\n"):
            text += "\n"
        return text + "\n" + replacement
    next_start = text.find("\n## ", start + len(heading))
    if next_start == -1:
        return text[:start] + replacement
    return text[:start] + replacement + text[next_start:]

text = path.read_text(encoding="utf-8") if path.exists() else ""
text = replace_section(text, "## Current Focus\n", focus_replacement)
text = replace_section(text, "## Next Action\n", next_action_replacement)

entry = (
    f"\n\n## Focus Change {timestamp}\n\n"
    "Focus: Direction -> Artifact\n"
    f"Trigger: {trigger}\n"
    f"Selected/improved demo: {selected}\n"
    f"Artifact action: {artifact_action}\n"
    f"Proof/caveat: {proof_caveat}\n"
    f"Decision: {next_question}\n"
)

path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(text.rstrip() + entry, encoding="utf-8")
PY

.agent/scripts/devloop-sync >/dev/null
printf '%s\n' "$radar"
