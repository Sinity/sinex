#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: .agent/scripts/devloop-meta [trigger] [failure-hypothesis] [evidence] [change-considered] [change-made] [change-deferred] [next-tripwire]

Append a self-audit template for agent/process failure modes. Use when the
operator corrects process behavior, a loop stalls, a repeated friction appears,
or before a handoff after substantial work.

Missing fields are recorded as explicit "not supplied" statements, not TODO
placeholders. Literal TODO placeholders are rejected so this helper cannot
create a log entry that fails devloop-review hygiene.
EOF
  exit 0
fi

trigger="${1:-scheduled meta-audit}"
failure_hypothesis="${2:-not supplied; classify during the next concrete meta pass}"
evidence="${3:-not supplied; inspect the operating log, review output, and recent proof costs before claiming a process finding}"
change_considered="${4:-not supplied; no process change selected yet}"
change_made="${5:-none in this entry}"
change_deferred="${6:-none in this entry}"
next_tripwire="${7:-run devloop-review and devloop-status before the next broad proof or context-cleared handoff}"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

for field in \
  "$trigger" \
  "$failure_hypothesis" \
  "$evidence" \
  "$change_considered" \
  "$change_made" \
  "$change_deferred" \
  "$next_tripwire"
do
  if [[ "$field" =~ (^|[[:space:]])TODO(:|$) ]]; then
    printf 'error: devloop-meta fields must be concrete; refuse literal TODO placeholder: %s\n' "$field" >&2
    exit 2
  fi
done

path=".agent/conductor-devloop/OPERATING-LOG.md"
timestamp="$(date --iso-8601=seconds)"
mkdir -p "$(dirname "$path")"

cat >>"$path" <<EOF

## $timestamp — meta-audit

Loop phase: reflect | velocity
Focus: Meta -> Velocity
Trigger: $trigger
Failure hypothesis: $failure_hypothesis
Evidence for/against: $evidence
Process/tooling change considered: $change_considered
Change made now: $change_made
Change deferred: $change_deferred
Next tripwire: $next_tripwire
EOF

printf '%s\n' "$path"
