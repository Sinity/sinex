# Sinex Development Environment Variables
# Copy this file to `.env` (which stays untracked) and customize as needed.

# Database connection (matches what's set in flake.nix devShell)
DATABASE_URL=postgresql:///sinex_dev?host=/run/postgresql
PGHOST=/run/postgresql
PGUSER=sinity
PGDATABASE=sinex_dev

# Optional overrides
# DATABASE_NAME=sinex_dev
# REDIS_URL=redis://localhost:6379
# RUST_LOG=debug
# SINEX_WORK_DIR=/tmp/sinex

# RPC authentication
# SINEX_RPC_TOKEN=generate-a-random-secret
# SINEX_RPC_TOKEN_FILE=/path/to/secret.txt
# SINEX_GATEWAY_ALLOW_INSECURE=0    # Set to 1 only for local tests

# Test harness toggles
# SINEX_TEST_LOG_ALL=1            # Emit detailed run logs for every test (default: failures only)
# SINEX_TEST_METRICS=1            # Append per-test timings to target/sinex-test-metrics.jsonl
# SINEX_TEST_METRICS_PATH=...     # Override metrics file location
