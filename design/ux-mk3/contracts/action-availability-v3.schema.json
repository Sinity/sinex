{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActionAvailability v3",
  "type": "object",
  "required": [
    "id",
    "label",
    "state",
    "side_effect"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "state": {
      "enum": [
        "enabled",
        "disabled",
        "target",
        "loading",
        "dangerous",
        "partial",
        "unavailable"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "shortcut": {
      "type": [
        "string",
        "null"
      ]
    },
    "command_equivalent": {
      "type": [
        "string",
        "null"
      ]
    },
    "rpc_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "side_effect": {
      "enum": [
        "read",
        "compose",
        "write",
        "admin",
        "destructive"
      ]
    },
    "dry_run_available": {
      "type": "boolean",
      "default": false
    },
    "requires_confirmation": {
      "type": "boolean",
      "default": false
    },
    "audit_output_ref": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
