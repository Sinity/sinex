{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPackView v3 target",
  "type": "object",
  "required": [
    "id",
    "state",
    "intent",
    "items",
    "omitted",
    "caveats",
    "budget"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "state": {
      "enum": [
        "draft",
        "ready",
        "blocked",
        "exported",
        "stale"
      ]
    },
    "intent": {
      "type": "object",
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "omitted": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": true
    },
    "manifest": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
