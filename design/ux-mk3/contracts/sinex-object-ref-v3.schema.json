{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SinexObjectRef v3",
  "type": "object",
  "required": [
    "kind",
    "id"
  ],
  "properties": {
    "kind": {
      "enum": [
        "event",
        "source_unit",
        "source_material",
        "material_anchor",
        "document",
        "document_chunk",
        "task",
        "semantic_lane",
        "semantic_entity",
        "semantic_relation",
        "operation",
        "replay_run",
        "snapshot",
        "dlq_message",
        "context_pack",
        "moment_candidate",
        "privacy_session",
        "caveat",
        "rpc_method",
        "command"
      ]
    },
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "anchor": {
      "type": "object",
      "additionalProperties": true
    },
    "stable": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
