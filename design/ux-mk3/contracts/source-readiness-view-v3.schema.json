{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceReadinessView v3",
  "type": "object",
  "required": [
    "source_unit",
    "status",
    "latest",
    "caveats",
    "actions"
  ],
  "properties": {
    "source_unit": {
      "$ref": "sinex-object-ref-v3.schema.json"
    },
    "family": {
      "type": "string"
    },
    "status": {
      "enum": [
        "ready",
        "partial",
        "stale",
        "missing",
        "drift",
        "unparsed",
        "blocked",
        "unknown"
      ]
    },
    "latest": {
      "type": "object",
      "additionalProperties": true
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true
    },
    "continuity": {
      "type": "object",
      "additionalProperties": true
    },
    "drift": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "materials": {
      "type": "array",
      "items": {
        "$ref": "sinex-object-ref-v3.schema.json"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "action-availability-v3.schema.json"
      }
    }
  }
}
