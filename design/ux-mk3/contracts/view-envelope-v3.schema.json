{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ViewEnvelope v3",
  "type": "object",
  "required": [
    "schema_version",
    "view_id",
    "generated_at",
    "source_surface",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "sinex.view-envelope/v3"
    },
    "view_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_surface": {
      "type": "string"
    },
    "runtime_target": {
      "type": [
        "string",
        "null"
      ]
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true
    },
    "query_echo": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "privacy_state": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "action-availability-v3.schema.json"
      }
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
