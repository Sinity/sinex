  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                name,\n                kind,\n                base_epoch_id,\n                candidate_epoch_id,\n                scope,\n                status,\n                purpose,\n                operation_id,\n                created_at as \"created_at: Timestamp\",\n                completed_at as \"completed_at: Timestamp\",\n                expires_at as \"expires_at: Timestamp\"\n            FROM semantic.lanes\n            WHERE ($1::text IS NULL OR status = $1)\n            ORDER BY created_at DESC, id DESC\n            LIMIT $2\n            ",
