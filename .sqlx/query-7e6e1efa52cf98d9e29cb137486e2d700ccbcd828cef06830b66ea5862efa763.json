{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                fr.id, fr.rule_id, fr.event_source, fr.event_type,\n                fr.field_path, fr.priority\n            FROM privacy.field_rules fr\n            JOIN privacy.rules r ON r.id = fr.rule_id\n            WHERE $1::text IS NULL OR r.name = $1\n            ORDER BY fr.priority DESC\n            ",
