  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                baseline_lane_id,\n                candidate_lane_id,\n                diff_kind,\n                counts,\n                examples,\n                report_hash,\n                created_at as \"created_at: Timestamp\"\n            FROM semantic.lane_diffs\n            WHERE baseline_lane_id = $1 OR candidate_lane_id = $1\n            ORDER BY created_at DESC, id DESC\n            LIMIT $2\n            ",
