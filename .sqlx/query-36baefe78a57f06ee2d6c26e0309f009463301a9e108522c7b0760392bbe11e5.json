  "query": "\n        SELECT\n            id, start_time, end_time, source_identifier, material_kind, status\n        FROM raw.source_material_registry\n        WHERE source_identifier = $1\n          AND ($2::text IS NULL OR material_kind = $2)\n        ORDER BY start_time ASC NULLS LAST\n        ",
