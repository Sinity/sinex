{
  "description": "Hourly per-node throughput, latency, and queue depth from node_stats_1h.",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "${DS_POSTGRES}",
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Events processed per node",
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, node_id AS metric, events_processed AS value FROM sinex_telemetry.node_stats_1h WHERE bucket > now() - INTERVAL '7 days' ORDER BY bucket",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": "${DS_POSTGRES}",
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 2,
      "title": "Queue depth (p99)",
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, node_id AS metric, p99_queue_depth AS value FROM sinex_telemetry.node_stats_1h WHERE bucket > now() - INTERVAL '7 days' ORDER BY bucket",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": "${DS_POSTGRES}",
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 3,
      "title": "Processing latency p99 (ms)",
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, node_id AS metric, p99_latency_ms AS value FROM sinex_telemetry.node_stats_1h WHERE bucket > now() - INTERVAL '7 days' ORDER BY bucket",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "tags": ["sinex", "nodes"],
  "templating": {"list": []},
  "time": {"from": "now-7d", "to": "now"},
  "timezone": "browser",
  "title": "Sinex Node Stats (1h)",
  "uid": "sinex-node-stats-1h",
  "version": 1
