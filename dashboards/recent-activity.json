{
  "description": "Cross-source activity rollup from recent_activity_summary.",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "${DS_POSTGRES}",
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Events by source (last 24h)",
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, source AS metric, event_count AS value FROM sinex_telemetry.recent_activity_summary WHERE bucket > now() - INTERVAL '24 hours' ORDER BY bucket",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": "${DS_POSTGRES}",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 10},
      "id": 2,
      "title": "Sources by activity (last 1h)",
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT source, SUM(event_count) AS events FROM sinex_telemetry.recent_activity_summary WHERE bucket > now() - INTERVAL '1 hour' GROUP BY source ORDER BY events DESC",
          "refId": "A"
        }
      ],
      "type": "table"
    }
  ],
  "schemaVersion": 38,
  "tags": ["sinex", "activity"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "title": "Sinex Recent Activity",
  "uid": "sinex-recent-activity",
  "version": 1
}
