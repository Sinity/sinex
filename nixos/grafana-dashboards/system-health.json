          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH latest_heartbeats AS (\n  SELECT DISTINCT ON (payload->>'component')\n    payload->>'component' as component,\n    ts_ingest as last_heartbeat,\n    EXTRACT(EPOCH FROM (NOW() - ts_ingest))::int as seconds_since_heartbeat,\n    payload->>'status' as status,\n    payload->>'version' as version,\n    payload->>'host' as host\n  FROM raw.events\n  WHERE event_type = 'heartbeat'\n    AND ts_ingest > NOW() - INTERVAL '10 minutes'\n  ORDER BY payload->>'component', ts_ingest DESC\n)\nSELECT \n  component,\n  host,\n  version,\n  last_heartbeat,\n  seconds_since_heartbeat,\n  CASE \n    WHEN seconds_since_heartbeat < 60 THEN 'healthy'\n    WHEN seconds_since_heartbeat < 120 THEN 'warning'\n    ELSE 'critical'\n  END as status\nFROM latest_heartbeats\nORDER BY component",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "time",
          "where": [
            {
              "name": "$__timeFilter",
              "params": [],
              "type": "macro"
            }
          ]
        }
      ],
