          "rawSql": "WITH latest_heartbeats AS (\n  SELECT DISTINCT ON (payload->>'component')\n    payload->>'component' as component,\n    EXTRACT(EPOCH FROM (NOW() - ts_ingest))::int as seconds_since_heartbeat\n  FROM raw.events\n  WHERE event_type = 'heartbeat'\n    AND ts_ingest > NOW() - INTERVAL '10 minutes'\n  ORDER BY payload->>'component', ts_ingest DESC\n),\nhealth_summary AS (\n  SELECT \n    COUNT(*) as total_components,\n    COUNT(CASE WHEN seconds_since_heartbeat <= 60 THEN 1 END) as healthy_components\n  FROM latest_heartbeats\n)\nSELECT \n  CASE \n    WHEN total_components = 0 THEN 0\n    ELSE (healthy_components * 100.0 / total_components)::numeric(5,2)\n  END as value\nFROM health_summary",
