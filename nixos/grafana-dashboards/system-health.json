          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH error_summary AS (\n  SELECT \n    source,\n    COUNT(*) as error_count,\n    MAX(ts_ingest) as last_error,\n    array_agg(DISTINCT event_type ORDER BY event_type) as error_types,\n    array_agg(DISTINCT payload->>'error_message' ORDER BY payload->>'error_message') \n      FILTER (WHERE payload->>'error_message' IS NOT NULL) as error_messages\n  FROM raw.events\n  WHERE ts_ingest > NOW() - INTERVAL '1 hour'\n    AND (event_type LIKE '%error%' OR event_type LIKE '%failed%' OR payload->>'level' = 'error')\n  GROUP BY source\n)\nSELECT \n  source,\n  error_count,\n  last_error,\n  array_to_string(error_types, ', ') as error_types,\n  CASE \n    WHEN array_length(error_messages, 1) > 0 \n    THEN array_to_string(error_messages[1:3], '; ')\n    ELSE 'No error messages'\n  END as recent_errors\nFROM error_summary\nORDER BY error_count DESC, last_error DESC",
