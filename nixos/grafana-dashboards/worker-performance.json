          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH source_stats AS (\n  SELECT \n    source,\n    COUNT(*) as total_events,\n    AVG(EXTRACT(EPOCH FROM (ts_coided - ts_orig)) * 1000) as avg_latency_ms,\n    MIN(ts_coided) as first_seen,\n    MAX(ts_coided) as last_seen\n  FROM core.events\n  WHERE ts_coided > NOW() - INTERVAL '1 hour'\n  GROUP BY source\n)\nSELECT \n  source,\n  total_events,\n  ROUND(avg_latency_ms::numeric, 2) as avg_latency_ms,\n  first_seen,\n  last_seen\nFROM source_stats\nORDER BY total_events DESC\nLIMIT 20",
          "refId": "A",
