          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT \n  ulid_to_uuid(event_id)::text as event_id,\n  worker_id,\n  status,\n  created_at,\n  started_at,\n  completed_at,\n  CASE \n    WHEN error_message IS NOT NULL THEN \n      CASE \n        WHEN length(error_message) > 100 THEN substring(error_message from 1 for 100) || '...'\n        ELSE error_message\n      END\n    ELSE NULL\n  END as error_message\nFROM sinex_schemas.promotion_queue\nWHERE status = 'failed'\n  AND created_at > NOW() - INTERVAL '24 hours'\nORDER BY created_at DESC\nLIMIT 50",
