          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', ts_coided) AS time,\n  'p50' as percentile,\n  percentile_cont(0.5) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (ts_coided - ts_orig)) * 1000) as \"Latency ms\"\nFROM core.events\nWHERE ts_coided >= NOW() - INTERVAL '2 hours'\nGROUP BY time\n\nUNION ALL\n\nSELECT\n  date_trunc('minute', ts_coided) AS time,\n  'p95' as percentile,\n  percentile_cont(0.95) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (ts_coided - ts_orig)) * 1000) as \"Latency ms\"\nFROM core.events\nWHERE ts_coided >= NOW() - INTERVAL '2 hours'\nGROUP BY time\n\nORDER BY time ASC",
          "refId": "A",
