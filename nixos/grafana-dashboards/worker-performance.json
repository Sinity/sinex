      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH worker_stats AS (\n  SELECT \n    worker_id,\n    COUNT(*) as total_processed,\n    COUNT(CASE WHEN status = 'succeeded' THEN 1 END) as succeeded_count,\n    COUNT(CASE WHEN status = 'failed' THEN 1 END) as failed_count,\n    AVG(CASE WHEN status = 'succeeded' THEN EXTRACT(EPOCH FROM (completed_at - started_at)) * 1000 END) as avg_processing_time_ms,\n    MIN(started_at) as first_task,\n    MAX(completed_at) as last_task\n  FROM sinex_schemas.promotion_queue\n  WHERE completed_at > NOW() - INTERVAL '1 hour'\n    AND worker_id IS NOT NULL\n  GROUP BY worker_id\n)\nSELECT \n  worker_id,\n  total_processed,\n  succeeded_count,\n  failed_count,\n  ROUND(avg_processing_time_ms::numeric, 2) as avg_processing_time_ms,\n  ROUND((succeeded_count * 100.0 / NULLIF(total_processed, 0))::numeric, 2) as success_rate,\n  first_task,\n  last_task\nFROM worker_stats\nORDER BY total_processed DESC",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "time",
          "where": [
            {
              "name": "$__timeFilter",
              "params": [],
              "type": "macro"
            }
          ]
        }
      ],
      "title": "Worker Performance Summary (1h)",
      "type": "table"
