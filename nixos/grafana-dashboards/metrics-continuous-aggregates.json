          "rawQuery": true,
          "rawSql": "SELECT \n  date_trunc('hour', bucket) as time,\n  'Raw Events Aggregated' as series,\n  SUM(sample_count) as \"Count\"\nFROM metrics_1min\nWHERE bucket >= NOW() - INTERVAL '7 days'\nGROUP BY date_trunc('hour', bucket)\n\nUNION ALL\n\nSELECT \n  date_trunc('hour', bucket) as time,\n  '1-min Aggregates Created' as series,\n  COUNT(*) as \"Count\"\nFROM metrics_1min\nWHERE bucket >= NOW() - INTERVAL '7 days'\nGROUP BY date_trunc('hour', bucket)\n\nORDER BY time ASC",
