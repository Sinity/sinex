          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT \n  m.view_name,\n  m.view_definition,\n  j.last_run_started_at as last_refresh,\n  EXTRACT(EPOCH FROM (NOW() - j.last_run_started_at)) * 1000000000 as refresh_lag,\n  c.reltuples::bigint as rows,\n  pg_size_pretty(pg_total_relation_size(c.oid)) as size,\n  j.job_status\nFROM timescaledb_information.continuous_aggregates m\nLEFT JOIN timescaledb_information.jobs j ON j.hypertable_name = m.view_name\nLEFT JOIN pg_class c ON c.relname = m.view_name\nWHERE m.view_name LIKE 'metrics_%'\nORDER BY m.view_name",
