      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH performance_test AS (\n  -- Test query on continuous aggregate\n  SELECT \n    'metrics_1min (aggregate)' as query_type,\n    (SELECT COUNT(*) FROM metrics_1min WHERE bucket >= NOW() - INTERVAL '24 hours') as rows_returned,\n    (SELECT EXTRACT(MILLISECONDS FROM query_start) FROM pg_stat_activity WHERE query LIKE '%metrics_1min%' AND state = 'active' LIMIT 1) as query_time_ms\n  \n  UNION ALL\n  \n  -- Test equivalent query on raw data\n  SELECT \n    'raw.events (equivalent)' as query_type,\n    (SELECT COUNT(*) FROM (\n       SELECT date_trunc('minute', ts_ingest), host\n       FROM metrics.collector_events \n       WHERE ts_ingest >= NOW() - INTERVAL '24 hours'\n       GROUP BY date_trunc('minute', ts_ingest), host\n     ) raw_equivalent) as rows_returned,\n    NULL as query_time_ms\n),\nrow_counts AS (\n  SELECT \n    'metrics.collector_events' as table_name,\n    'Raw metrics events' as description,\n    COUNT(*) as total_rows,\n    pg_size_pretty(pg_total_relation_size('metrics.collector_events')) as table_size\n  FROM metrics.collector_events\n  WHERE ts_ingest >= NOW() - INTERVAL '7 days'\n  \n  UNION ALL\n  \n  SELECT \n    'metrics_1min' as table_name,\n    '1-minute aggregates' as description,\n    COUNT(*) as total_rows,\n    pg_size_pretty(pg_total_relation_size('metrics_1min')) as table_size\n  FROM metrics_1min\n  WHERE bucket >= NOW() - INTERVAL '7 days'\n  \n  UNION ALL\n  \n  SELECT \n    'metrics_1hour' as table_name,\n    '1-hour aggregates' as description,\n    COUNT(*) as total_rows,\n    pg_size_pretty(pg_total_relation_size('metrics_1hour')) as table_size\n  FROM metrics_1hour\n  WHERE bucket >= NOW() - INTERVAL '7 days'\n)\nSELECT \n  table_name,\n  description,\n  total_rows,\n  table_size,\n  CASE \n    WHEN total_rows > 0 THEN \n      ROUND((total_rows * 100.0 / (SELECT MAX(total_rows) FROM row_counts))::numeric, 2)\n    ELSE 0\n  END as compression_ratio_percent\nFROM row_counts\nORDER BY total_rows DESC",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "time",
          "where": [
            {
              "name": "$__timeFilter",
              "params": [],
              "type": "macro"
            }
          ]
        }
      ],
