      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH event_sequences AS (\n  SELECT \n    source,\n    event_type,\n    LAG(event_type) OVER (PARTITION BY source ORDER BY ts_ingest) as prev_event,\n    LEAD(event_type) OVER (PARTITION BY source ORDER BY ts_ingest) as next_event\n  FROM raw.events\n  WHERE ts_ingest > NOW() - INTERVAL '1 hour'\n    AND source NOT LIKE 'sinex.metrics.%'\n)\nSELECT \n  prev_event || ' → ' || event_type || ' → ' || next_event as sequence,\n  COUNT(*) as occurrences\nFROM event_sequences\nWHERE prev_event IS NOT NULL AND next_event IS NOT NULL\nGROUP BY sequence\nHAVING COUNT(*) > 1\nORDER BY occurrences DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Common Event Sequences",
      "type": "table"
    },
