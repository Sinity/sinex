          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  ts_ingest as time,\n  source,\n  event_type,\n  CASE \n    WHEN ts_orig IS NOT NULL THEN EXTRACT(EPOCH FROM (ts_ingest - ts_orig))::numeric(10,2)\n    ELSE NULL\n  END as lag_seconds,\n  jsonb_pretty(payload) as payload\nFROM raw.events\nWHERE ts_ingest > NOW() - INTERVAL '5 minutes'\n  AND source NOT LIKE 'sinex.metrics.%'\nORDER BY ts_ingest DESC\nLIMIT 100",
          "refId": "A"
        }
