      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH minute_stats AS (\n  SELECT \n    date_trunc('minute', ts_ingest) as minute,\n    source,\n    COUNT(*) as event_count,\n    AVG(COUNT(*)) OVER (\n      PARTITION BY source \n      ORDER BY date_trunc('minute', ts_ingest) \n      ROWS BETWEEN 30 PRECEDING AND CURRENT ROW\n    ) as rolling_avg,\n    STDDEV(COUNT(*)) OVER (\n      PARTITION BY source \n      ORDER BY date_trunc('minute', ts_ingest) \n      ROWS BETWEEN 30 PRECEDING AND CURRENT ROW\n    ) as rolling_stddev\n  FROM raw.events\n  WHERE ts_ingest > NOW() - INTERVAL '2 hours'\n    AND source NOT LIKE 'sinex.metrics.%'\n  GROUP BY minute, source\n)\nSELECT \n  minute as time,\n  source,\n  CASE \n    WHEN rolling_stddev > 0 THEN ABS(event_count - rolling_avg) / rolling_stddev\n    ELSE 0\n  END as sigma_deviation\nFROM minute_stats\nWHERE ABS(event_count - rolling_avg) > 2 * rolling_stddev\n  AND rolling_stddev > 0\nORDER BY minute DESC",
          "refId": "A"
        }
      ],
      "title": "Event Rate Anomalies (>2σ)",
      "type": "timeseries"
    }
