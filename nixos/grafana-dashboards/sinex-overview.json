          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_metrics AS (\n  SELECT \n    payload->'sources' as sources\n  FROM raw.events\n  WHERE source = 'sinex.metrics.collector'\n  ORDER BY ts_ingest DESC\n  LIMIT 1\n)\nSELECT \n  source.key as source,\n  (source.value->>'events_total')::bigint as events_total,\n  (source.value->>'errors_total')::bigint as errors_total,\n  (source.value->>'bytes_processed')::bigint as bytes_processed,\n  (source.value->>'last_event_time')::timestamptz as last_event\nFROM latest_metrics, jsonb_each(sources) as source\nORDER BY events_total DESC",
          "refId": "A"
        }
      ],
