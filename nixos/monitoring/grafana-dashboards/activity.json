          "rawSql": "SELECT command, shell, SUM(total_executions)::bigint AS total_executions, SUM(successful_executions)::bigint AS successful_executions, SUM(failed_executions)::bigint AS failed_executions, ROUND(AVG(avg_duration_ms)::numeric, 2) AS avg_duration_ms FROM sinex_telemetry.command_frequency_hourly WHERE $__timeFilter(bucket) GROUP BY command, shell ORDER BY total_executions DESC, command ASC LIMIT 25",
