      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "sinex-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT aggregate, latest_bucket, ROUND(EXTRACT(EPOCH FROM (NOW() - latest_bucket)) / 60.0, 2) AS minutes_behind FROM (SELECT 'gateway_stats_1h' AS aggregate, MAX(bucket) AS latest_bucket FROM sinex_telemetry.gateway_stats_1h UNION ALL SELECT 'stream_stats_1h' AS aggregate, MAX(bucket) AS latest_bucket FROM sinex_telemetry.stream_stats_1h UNION ALL SELECT 'assembly_stats_1h' AS aggregate, MAX(bucket) AS latest_bucket FROM sinex_telemetry.assembly_stats_1h UNION ALL SELECT 'node_stats_1h' AS aggregate, MAX(bucket) AS latest_bucket FROM sinex_telemetry.node_stats_1h UNION ALL SELECT 'metric_counters_1h' AS aggregate, MAX(bucket) AS latest_bucket FROM sinex_telemetry.metric_counters_1h UNION ALL SELECT 'ingestd_batch_stats_1h' AS aggregate, MAX(bucket) AS latest_bucket FROM sinex_telemetry.ingestd_batch_stats_1h) freshness ORDER BY aggregate ASC",
          "refId": "A"
        }
      ],
      "title": "Continuous Aggregate Freshness",
      "type": "table"
    }
