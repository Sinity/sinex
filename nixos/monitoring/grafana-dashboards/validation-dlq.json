          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('15 minutes', ts_coided) AS time, percentile_cont(0.5) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (ts_coided - ts_orig)) * 1000) AS p50_latency_ms, percentile_cont(0.95) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (ts_coided - ts_orig)) * 1000) AS p95_latency_ms FROM core.events WHERE $__timeFilter(ts_coided) AND ts_orig IS NOT NULL AND ts_coided > ts_orig GROUP BY time ORDER BY time ASC",
          "refId": "A"
        }
      ],
      "title": "End-to-End Latency (p50 / p95)",
      "type": "timeseries"
